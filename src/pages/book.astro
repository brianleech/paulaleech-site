---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Book a Session — Paula Leech">
  <section class="relative max-w-3xl mx-auto px-6 py-20 text-center">
    <div class="blob" style="background:var(--color-peach); width:300px; height:300px; top:0; left:-100px;"></div>
    <div class="blob" style="background:var(--color-sage); width:240px; height:240px; bottom:0; right:-80px;"></div>
    <h1 class="relative">Book a Session</h1>
    <p class="mt-6 max-w-xl mx-auto relative">Pick the path that fits — therapy, supervision, or a quick consult. All sessions are virtual.</p>

    <div class="mt-16 grid md:grid-cols-2 gap-6 relative text-left">
      <div class="p-8 bg-[var(--color-cream-deep)]/60 rounded-2xl">
        <h3>Therapy Clients</h3>
        <p class="mt-3 text-sm">For ongoing sex therapy in <strong>Massachusetts or Oregon</strong>. Includes intake forms, secure telehealth, and insurance support through SimplePractice.</p>
        <!-- TODO: SimplePractice client portal URL goes here once Paula is onboarded -->
        <a href="/contact" class="btn mt-6">Request an Intake</a>
      </div>

      <div class="p-8 bg-[var(--color-cream-deep)]/60 rounded-2xl">
        <h3>Supervisees & Consults</h3>
        <p class="mt-3 text-sm">Individual or group supervision (AASECT-aligned), peer consultation, or a brief intro call before a training. Worldwide.</p>
        <!-- TODO: Cal.com embed URL goes here -->
        <a href="/contact" class="btn mt-6">Schedule</a>
      </div>
    </div>

    <p class="mt-12 text-sm relative" style="color:var(--color-ink-soft);">Not sure which is right? <a href="/contact">Send a quick note</a> and we'll point you in the right direction.</p>
  </section>
</Layout>
