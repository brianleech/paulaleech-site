---
import Layout from '../layouts/Layout.astro';
const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');

// Real appearances pulled from paulaleech.com "Mentioned In" — newest first.
const appearances = [
  { date: "AUG 25", title: "From Tension to Trust: Healing Sexual Anxiety",                outlet: "Wise Body Sex Therapy Podcast", kind: "Podcast", url: "https://podcasts.apple.com/ca/podcast/from-tension-to-trust-paula-leech-on-healing-sexual-anxiety/id1833251163?i=1000721958902" },
  { date: "MAR 25", title: "Overcoming Anxiety in Sex and Relationships",                  outlet: "The Natasha Helfer Podcast",    kind: "Podcast", url: "https://open.spotify.com/episode/3BHIOdjTLVDyO29Ft7WhBq?si=fe72e0d38a6a4b65" },
  { date: "NOV 24", title: "Overcoming Anxiety in Sex",                                    outlet: "The Better Sex Podcast",        kind: "Podcast", url: "https://intimacywithease.com/269-overcoming-anxiety-in-sex-with-paula-leech/" },
  { date: "APR 24", title: "The Importance of Embodiment in the Expression of Sexuality",  outlet: "In This Body Podcast",          kind: "Podcast", url: "https://in-this-body.com/episodes/paula-leech" },
  { date: "JUL 22", title: "Vanilla or Kinky?",                                            outlet: "Female Pleasure Society",       kind: "Podcast", url: "https://twitter.com/i/spaces/1mnGedalEmAKX?s=20" },
  { date: "JUN 22", title: "From Fantasy to Reality",                                      outlet: "Female Pleasure Society",       kind: "Podcast", url: "https://twitter.com/i/spaces/1mnxedzOEDRJX" },
  { date: "MAY 22", title: "Postpartum Sexuality",                                         outlet: "Sex Therapy Podcast",           kind: "Podcast", url: "https://podcasts.apple.com/us/podcast/postpartum-sexuality-w-paula-leech-ep-73/id1489854551?i=1000554666651" },
  { date: "MAY 22", title: "Paula's Story: Infertility, Grief, and Finding Spirituality",  outlet: "Sexvangelicals Podcast",        kind: "Podcast", url: "https://podcasts.apple.com/us/podcast/paulas-story-infertility-grief-and-finding-spirituality/id1541092846?i=1000559276583" },
  { date: "APR 22", title: "The Danger of \u201CPremature Diagnosis\u201D",                outlet: "Our Two Cents Podcast",         kind: "Podcast", url: "https://www.ourtwocentspodcast.com/podcast/episode/1bc96911/134-paula-leech-the-danger-of-premature-diagnosis" },
  { date: "FEB 22", title: "Pregnancy and Postpartum Challenges for Sex",                  outlet: "Better Sex Podcast",            kind: "Podcast", url: "https://intimacywithease.com/pregnancy-and-postpartum-challenges-for-sex-paula-leech/" },
  { date: "MAY 21", title: "Sex, Sexuality, and Mental Health",                            outlet: "Beautiful Self Org",            kind: "Talk",    url: "https://www.facebook.com/1670418783187462/videos/190005119641928" },
  { date: "APR 21", title: "Intimacy, Performance, and Desire",                            outlet: "Love and Healing Podcast",      kind: "Podcast", url: "https://www.loveandhealingpodcast.com/blog/intimacy-ed-female-pain-and-loss-of-desire-with-relationship-therapist-paula-leech" },
  { date: "APR 21", title: "A Conversation with Sex Therapist, Paula Leech",               outlet: "Love and Healing Podcast",      kind: "Podcast", url: "https://www.loveandhealingpodcast.com/blog/a-conversation-with-sex-therapist-paula-leech" },
  { date: "FEB 21", title: "Demystifying Desire",                                          outlet: "Beautiful Self Org",            kind: "Talk",    url: "https://www.instagram.com/p/CLGDeqJBTe4/" },
  { date: "DEC 20", title: "Sex and the Survivor",                                         outlet: "Beautiful Self Org",            kind: "Talk",    url: "https://www.instagram.com/p/CJqtbsPAqA2/" },
  { date: "SEP 20", title: "What is Sex Therapy Like?",                                    outlet: "Better Sex Podcast",            kind: "Podcast", url: "https://intimacywithease.com/what-is-sex-therapy-like-paula-leech/" },
];
---
<Layout title="Press & Appearances — Paula Leech">

  <section class="mx-auto max-w-[1400px] px-12 lg:px-20 pt-16 md:pt-24 pl-reveal">
    <p class="pl-label">Press &amp; Appearances</p>
    <h1 style="
      font-family: var(--font-display);
      font-weight: 500;
      font-variation-settings: 'opsz' 144, 'SOFT' 60;
      font-size: clamp(3rem, 9vw, 7rem);
      line-height: 0.9;
      letter-spacing: -0.04em;
      margin-top: 1rem;
      color: var(--color-ink);
    ">
      Where I've<br/><em style="font-weight: 400;">shown up.</em>
    </h1>
    <p class="mt-8 max-w-2xl" style="font-family: var(--font-display); font-weight: 400; font-style: italic; font-size: clamp(1.25rem, 2vw, 1.5rem); line-height: 1.4; color: var(--color-ink-soft);">
      Podcasts, articles, talks, and a handful of conversations I'm glad I said yes to.
    </p>
  </section>

  <section class="mx-auto max-w-[1400px] px-12 lg:px-20 mt-20 md:mt-32 pl-reveal">
    <div class="pl-grid">
      <div class="col-span-12 md:col-span-12">
        {appearances.map(a => (
          <a href={a.url} target="_blank" rel="noopener" class="pl-ledger" style="cursor: pointer; text-decoration: none;">
            <span class="pl-label" style="min-width: 5.5rem;">{a.date}</span>
            <span style="font-family: var(--font-display); font-size: clamp(1.15rem, 2vw, 1.5rem);">
              {a.title}
              <span class="pl-label ml-3">{a.outlet} · {a.kind}</span>
            </span>
            <span class="pl-label">{a.kind === 'Podcast' ? 'Listen' : a.kind === 'Article' ? 'Read' : 'Watch'} →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Inquiry CTA -->
  <section class="mx-auto max-w-[1400px] px-12 lg:px-20 mt-32 md:mt-40 mb-32 pl-reveal">
    <div class="pl-grid items-center" style="padding: 3rem 2rem; background: color-mix(in srgb, var(--color-honey) 35%, transparent); border-radius: 1rem;">
      <div class="col-span-12 md:col-span-8">
        <span class="pl-label">For Press</span>
        <h2 style="font-family: var(--font-display); font-style: italic; font-weight: 400; font-size: clamp(1.75rem, 3.4vw, 2.75rem); line-height: 1.1; margin-top: 0.5rem; letter-spacing: -0.015em;">
          Looking to interview Paula?
        </h2>
        <p class="mt-4 text-base" style="color: var(--color-ink-soft); max-width: 50ch; line-height: 1.6;">
          Available for interviews on sex, anxiety, intimacy, and the conversations most of us were never taught to have.
        </p>
      </div>
      <div class="col-span-12 md:col-span-4 mt-6 md:mt-0 md:text-right">
        <a href="mailto:paula@paulaleech.com?subject=Press%20inquiry" class="pl-pill" style="padding: 0.95rem 1.8rem;">Send a press inquiry →</a>
      </div>
    </div>
  </section>

</Layout>
