---
import Layout from '../layouts/Layout.astro';

const press = [
  { title: 'From Tension to Trust: Paula Leech on Healing Sexual Anxiety', outlet: 'Wise Body Sex Therapy Podcast', date: 'Aug 2025', href: '#' },
  { title: 'Overcoming Anxiety in Sex and Relationships', outlet: 'The Better Sex Podcast', date: 'Nov 2024', href: '#' },
  { title: 'The Importance of Embodiment in the Expression of Sexuality', outlet: 'In This Body Podcast', date: 'Apr 2024', href: '#' },
  { title: '94: Overcoming Anxiety in Sex and Relationships with Paula Leech', outlet: 'The Natasha Helfer Podcast', date: 'Mar 2024', href: '#' },
  { title: '224: Pregnancy and Postpartum Challenges for Sex – Paula Leech', outlet: 'Better Sex', date: 'Apr 2022', href: '#' },
  { title: 'Sex and Anxiety', outlet: 'Peanut App Pods', date: 'Aug 2022', href: '#' },
  { title: 'Paula\'s Story: Infertility, Grief, and Finding Spirituality', outlet: 'Sexvangelicals Podcast', date: 'May 2022', href: '#' },
  { title: 'The Danger of "Premature Diagnosis"', outlet: 'Our Two Cents Podcast', date: 'Apr 2022', href: '#' },
  { title: 'Female Pleasure Society Twitter Space', outlet: 'Female Pleasure Society', date: '2022', href: '#' },
  { title: 'Featured in CNN Health', outlet: 'CNN Health', date: '', href: '#' },
  { title: 'Featured in Women\'s Health', outlet: "Women's Health", date: '', href: '#' },
];
---
<Layout title="Press & Podcasts — Paula Leech">
  <section class="relative max-w-3xl mx-auto px-6 py-20">
    <div class="blob" style="background:var(--color-sage); width:300px; height:300px; top:0; right:-100px;"></div>
    <h1 class="relative">Press & Podcasts</h1>
    <p class="mt-6">A selection of conversations, interviews, and features. <em class="text-sm" style="color:var(--color-clay);">Links are placeholders — we'll fill in the real URLs together.</em></p>

    <ul class="mt-12 space-y-6 list-none p-0">
      {press.map(p => (
        <li class="border-b border-[var(--color-clay)]/20 pb-6">
          <div class="text-xs uppercase tracking-widest" style="color:var(--color-clay);">{p.outlet} {p.date && `· ${p.date}`}</div>
          <a href={p.href} class="block mt-1 text-lg no-underline hover:text-[var(--color-clay)]" style="font-family:var(--font-serif); color:var(--color-ink); text-decoration:none;">{p.title}</a>
        </li>
      ))}
    </ul>
  </section>
</Layout>
