---
import Layout from '../layouts/Layout.astro';
import headRose from '../assets/illustrations/HeadRose.png';
import headSage from '../assets/illustrations/HeadSage.png';
import infinity from '../assets/illustrations/infininity.png';
import hands from '../assets/illustrations/HandsGraphic2.png';
import quotesLeft from '../assets/illustrations/LeftQuote.png';
import quotesRight from '../assets/illustrations/RightQuote.png';
import trainingsData from '../data/trainings.json';
import bookMockup from '../assets/illustrations/BookMockup.png';
import clouds from '../assets/illustrations/Clouds.png';
import armTouch from '../assets/illustrations/HandsCrossed.png';
import groupSupervision from '../assets/illustrations/MultiHeads.png';
import theraMedium from '../assets/illustrations/MirroredHeads.png';
import logoTheCut from '../assets/logos/press/the-cut.png';
import logoNatasha from '../assets/logos/press/natasha-helfer-podcast.jpg';
import logoInThisBody from '../assets/logos/press/in-this-body.jpg';
const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');

// Split trainings by date: anything dated today or later is upcoming,
// anything earlier is "past" (most-recent 3 shown). dateLabel === 'On-demand'
// or 'Recurring' is treated as always-current (uses date 9999 in JSON).
const today = new Date().toISOString().slice(0, 10);
const upcoming = trainingsData
  .filter(t => (t.date || '9999-12-31') >= today)
  .sort((a, b) => (a.date || '').localeCompare(b.date || ''));
const past = trainingsData
  .filter(t => (t.date || '9999-12-31') < today)
  .sort((a, b) => (b.date || '').localeCompare(a.date || ''))
  .slice(0, 3);
---
<Layout title="Paula Leech — Sex Therapy, Supervision & Courses" headerCredentials={true}>

  <!-- HERO: huge cropped heads flanking the wordmark, type top-left -->
  <section class="relative pl-hero-section" style="min-height: 78vh;">
    <!-- LEFT head (rose). Outer = JS momentum; inner = CSS ambient float. -->
    <div class="pl-momentum pl-fit-vertical absolute pointer-events-none" data-scroll="0.18" data-resize="0.4"
      style="right: calc(50% - 80px); z-index: 1; will-change: transform;">
      <img
        src={headRose.src}
        alt=""
        aria-hidden="true"
        class="pl-float-slow"
        style="
          display: block;
          width: clamp(360px, 42vw, 620px);
          height: auto;
          mix-blend-mode: multiply;
          opacity: 0.5;
        "
      />
    </div>

    <!-- RIGHT head (sage). Outer = JS momentum (opposite scroll bias); inner = CSS ambient float. -->
    <div class="pl-momentum pl-fit-vertical absolute pointer-events-none" data-scroll="-0.12" data-resize="-0.4"
      style="left: calc(50% - 80px); z-index: 1; will-change: transform;">
      <img
        src={headSage.src}
        alt=""
        aria-hidden="true"
        class="pl-float-slow-rev"
        style="
          display: block;
          width: clamp(360px, 42vw, 620px);
          height: auto;
          mix-blend-mode: multiply;
          opacity: 0.5;
        "
      />
    </div>

    <div class="relative z-10 mx-auto max-w-[1400px] px-12 lg:px-20 pt-10 md:pt-14" style="padding-top: calc(100px + 2.5rem);">
      <div class="pl-reveal">
        <h1
          class="pl-hero-title"
          style="
            font-family: var(--font-display);
            font-weight: 500;
            font-variation-settings: 'opsz' 144, 'SOFT' 60;
            font-size: clamp(3.5rem, 11vw, 10rem);
            line-height: 0.88;
            letter-spacing: -0.045em;
            color: var(--color-ink);
          "
        >
          P<span style="position: relative; display: inline-block;">au<span aria-label="pronouns she/her" style="
            position: absolute;
            right: 0;
            bottom: 100%;
            margin-bottom: -2.679em;
            text-align: right;
            font-family: var(--font-display);
            font-size: 0.12em;
            font-style: italic;
            font-weight: 400;
            letter-spacing: 0.01em;
            color: var(--color-ink);
            line-height: 1;
            white-space: nowrap;
            pointer-events: none;
          ">(she/her)</span></span>la<br/>Leech.
        </h1>
        <p style="
          font-family: var(--font-display);
          font-style: italic;
          font-weight: 400;
          font-size: clamp(1.5rem, 2.6vw, 2.1rem);
          line-height: 1.2;
          letter-spacing: -0.01em;
          color: var(--color-ink);
          margin-top: 1.5rem;
        ">
          Sex therapist, supervisor <span class="pl-subhead-break">&amp; author.</span>
        </p>
      </div>
    </div>
  </section>

  <style>
    @media (max-width: 768px) {
      .pl-hero-title {
        font-size: clamp(4.5rem, 18vw, 6rem) !important;
      }
      .pl-hero-title span span:last-child {
        font-size: 0.194em !important;
        margin-bottom: -1.1em !important;
      }
    }
    @media (max-width: 768px) {
      .pl-hero-section {
        min-height: calc(78vh - 100px) !important;
      }
      .pl-subhead-break {
        display: block;
      }
    }
  </style>

  <!-- IN SHORT — conversational fragments -->
  <section id="in-short" class="mx-auto max-w-[1400px] px-12 lg:px-20 mt-12 md:mt-16 pl-reveal" style="margin-top: calc(4rem - 150px); position: relative; z-index: 5;">
    <h2 class="pl-label" style="margin-bottom: 3rem;">In short.</h2>
    <div class="pl-grid">
      <div class="col-span-12 md:col-span-3">
        <span class="pl-section-word">A bit about me.</span>
        <p class="mt-4 text-base" style="color: var(--color-ink-soft); line-height: 1.55;">
          Sex therapist, clinical supervisor, and educator. AASECT certified.
        </p>
      </div>
      <div class="col-span-12 md:col-span-3 mt-10 md:mt-0">
        <span class="pl-section-word">Where to find me.</span>
        <p class="mt-4 text-base" style="color: var(--color-ink-soft); line-height: 1.55;">
          Therapy: Massachusetts, Oregon, and New York.<br/>
          Supervision: worldwide.
        </p>
      </div>
      <div class="col-span-12 md:col-span-3 mt-10 md:mt-0">
        <span class="pl-section-word">Where I specialize.</span>
        <p class="mt-4 text-base" style="color: var(--color-ink-soft); line-height: 1.55;">
          Anxiety, shame, mismatched desire, and the work of finding pleasure&nbsp;again.
        </p>
      </div>
      <div class="col-span-12 md:col-span-3 mt-10 md:mt-0">
        <span class="pl-section-word">How it tends to go.</span>
        <p class="mt-4 text-base" style="color: var(--color-ink-soft); line-height: 1.55;">
          Virtual or in-person sessions. Steady, direct, and compassionate &mdash; with a little levity when it helps.
        </p>
      </div>
    </div>
  </section>

  <!-- LEAD STATEMENT — bracketed by giant teal/rose quotes -->
  <section class="mx-auto max-w-[1400px] px-12 lg:px-20 mt-40 md:mt-56 relative pl-reveal">
    <div class="relative">
      <!-- Opening quote (left, just above text top) -->
      <span class="pl-float-slow absolute" style="top: -2rem; left: 1rem; display: inline-block;">
        <img src={quotesLeft.src} alt="" class="pl-quote-ornament block" style="
          width: clamp(70px, 8.5vw, 140px);
          height: auto;
          opacity: 0.5;
        " />
      </span>
      <!-- Closing quote (right, just below text bottom) -->
      <span class="pl-float-slow-rev absolute" style="bottom: -2.5rem; right: 1rem; display: inline-block;">
        <img src={quotesRight.src} alt="" class="pl-quote-ornament block" style="
          width: clamp(70px, 8.5vw, 140px);
          height: auto;
          opacity: 0.5;
        " />
      </span>

      <div class="pl-grid">
        <div class="col-span-12 md:col-start-3 md:col-span-8">
          <p style="
            font-family: var(--font-display);
            font-weight: 400;
            font-size: clamp(1.75rem, 3.4vw, 3rem);
            line-height: 1.2;
            letter-spacing: -0.018em;
            color: var(--color-ink);
          ">
            Anxiety, shame, disconnection &mdash;
            the parts of intimacy nobody taught us how to talk about.
            My work is to make the conversation possible,
            with steadiness and a little humor.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- LET'S WORK TOGETHER — Tarot deck -->
  <section class="mx-auto max-w-[1400px] px-12 lg:px-20 mt-40 md:mt-56 pl-reveal">
    <div class="pl-grid items-start">
      <div class="col-span-12 md:col-span-4">
        <span class="pl-label">Services</span>
        <h2 style="font-family: var(--font-display); font-size: clamp(2.25rem, 4.5vw, 3.75rem); line-height: 0.95; margin-top: 0.75rem; letter-spacing: -0.025em;">
          Let's work<br/><em style="font-weight: 400;">together.</em>
        </h2>
        <a href={`${BASE}/work-with-paula`} class="pl-pill mt-8 inline-flex">See all →</a>
      </div>
      <div class="col-span-12 md:col-span-8 mt-10 md:mt-0">
        <div class="pl-tarot-deck">
          <a href={`${BASE}/work-with-paula#therapy`} class="pl-tarot-card">
            <div class="pl-tarot-art">
              <img src={armTouch.src} alt="" aria-hidden="true" />
              <div class="pl-tarot-meta">MA · OR · NY</div>
            </div>
            <div>
              <div class="pl-tarot-title">Sex Therapy</div>
              <div class="pl-tarot-sub">Individuals &amp; couples</div>
              <div class="pl-tarot-cta">Begin →</div>
            </div>
          </a>
          <a href={`${BASE}/work-with-paula#supervision`} class="pl-tarot-card">
            <div class="pl-tarot-art">
              <img src={groupSupervision.src} alt="" aria-hidden="true" />
              <div class="pl-tarot-meta">Worldwide</div>
            </div>
            <div>
              <div class="pl-tarot-title">Clinical Supervision</div>
              <div class="pl-tarot-sub">Therapists &amp; CST candidates</div>
              <div class="pl-tarot-cta">Apply →</div>
            </div>
          </a>
          <a href={`${BASE}/courses`} class="pl-tarot-card">
            <div class="pl-tarot-art">
              <img src={theraMedium.src} alt="" aria-hidden="true" />
              <div class="pl-tarot-meta">Online</div>
            </div>
            <div>
              <div class="pl-tarot-title">Courses &amp; Trainings</div>
              <div class="pl-tarot-sub">Scheduled &amp; on-demand</div>
              <div class="pl-tarot-cta">Browse →</div>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- COURSES SPOTLIGHT — Manuscript ledger -->
  <section class="mx-auto max-w-[1400px] px-12 lg:px-20 mt-40 md:mt-56 pl-reveal">
    <div class="pl-grid items-start">
      <div class="col-span-12 md:col-span-4">
        <span class="pl-label">Now Booking</span>
        <h2 style="font-family: var(--font-display); font-size: clamp(2.25rem, 4.5vw, 3.75rem); line-height: 0.95; margin-top: 0.75rem; letter-spacing: -0.025em;">
          What's<br/><em style="font-weight: 400;">running now.</em>
        </h2>
        <a href={`${BASE}/courses`} class="pl-pill mt-8 inline-flex">Browse catalog →</a>
      </div>
      <div class="col-span-12 md:col-span-8 mt-10 md:mt-0">
        <div class="pl-ledger-manuscript">
          {upcoming.map(t => (
            <a href={`${BASE}${t.url || `/courses#${t.id}`}`} class="pl-ledger-row" style="text-decoration:none;">
              <span class={`pl-ledger-blot pl-ledger-blot--${t.blot || 'rose'}`} aria-hidden="true"></span>
              <span class="pl-ledger-date">{t.dateLabel}</span>
              <span class="pl-ledger-title">{t.title}<span class="pl-ledger-tag">{t.tag}</span></span>
              <span class="pl-ledger-price">{t.price ? `${t.price} →` : '→'}</span>
            </a>
          ))}
        </div>

        {past.length > 0 && (
          <div class="pl-past-trainings">
            <span class="pl-label" style="display: block; margin-top: 2.5rem; margin-bottom: 0.75rem;">Past Trainings</span>
            <div class="pl-ledger-manuscript pl-ledger-manuscript--past">
              {past.map(t => (
                <div class="pl-ledger-row">
                  <span class={`pl-ledger-blot pl-ledger-blot--${t.blot || 'rose'}`} aria-hidden="true"></span>
                  <span class="pl-ledger-date">{t.dateLabel}</span>
                  <span class="pl-ledger-title">{t.title}<span class="pl-ledger-tag">{t.tag}</span></span>
                  <span class="pl-ledger-price">Closed</span>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- PRESS — Apothecary labels w/ inline media -->
  <section class="mx-auto max-w-[1400px] px-12 lg:px-20 mt-40 md:mt-56 pl-reveal">
    <div class="pl-grid items-start">
      <div class="col-span-12 md:col-span-4">
        <span class="pl-label">Press &amp; Appearances</span>
        <h2 style="font-family: var(--font-display); font-size: clamp(2.25rem, 4.5vw, 3.75rem); line-height: 0.95; margin-top: 0.75rem; letter-spacing: -0.025em;">
          Where I've<br/><em style="font-weight: 400;">shown up.</em>
        </h2>
        <p class="mt-6 text-base" style="color: var(--color-ink-soft); max-width: 32ch; line-height: 1.6;">
          Podcasts, articles, talks, and a handful of conversations I'm glad I said yes to.
        </p>
        <a href={`${BASE}/press`} class="pl-pill mt-8 inline-flex">Full archive →</a>
      </div>
      <div class="col-span-12 md:col-span-8 mt-10 md:mt-0">
        <div class="pl-apothecary-wrap">
          <div class="pl-apothecary-shelf pl-apothecary-shelf--scroll" id="press-shelf">
          <div class="pl-bottle">
            <span class="pl-bottle-audio-mark" aria-hidden="true">♪</span>
            <div class="pl-bottle-header">
              <span class="pl-bottle-kicker">No. I · Podcast</span>
            </div>
            <div class="pl-bottle-spacer"></div>
            <div class="pl-bottle-title">Overcoming Anxiety in Sex &amp; Relationships.</div>
            <div class="pl-bottle-tincture">An hour with Natasha Helfer on the quiet panic that reshapes desire.</div>
            <div class="pl-bottle-spacer"></div>
            <div class="pl-bottle-meta">Mar 2025 · 1h 17m</div>
            <div class="pl-bottle-player">
              <iframe
                src="https://open.spotify.com/embed/episode/3BHIOdjTLVDyO29Ft7WhBq?utm_source=generator"
                width="100%"
                height="152"
                frameborder="0"
                allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
                loading="lazy"
                title="The Natasha Helfer Podcast — Overcoming Anxiety in Sex and Relationships with Paula Leech"
              ></iframe>
            </div>
            <a href="https://open.spotify.com/episode/3BHIOdjTLVDyO29Ft7WhBq" target="_blank" rel="noopener" class="pl-bottle-cork">Open on Spotify →</a>
          </div>

          <div class="pl-bottle">
            <span class="pl-bottle-audio-mark" aria-hidden="true">♪</span>
            <div class="pl-bottle-header">
              <span class="pl-bottle-kicker">No. II · Podcast</span>
            </div>
            <div class="pl-bottle-spacer"></div>
            <div class="pl-bottle-title">Pregnancy &amp; postpartum challenges for sex.</div>
            <div class="pl-bottle-tincture">A look at what shifts in desire and the body after kids — and what to do with it.</div>
            <div class="pl-bottle-spacer"></div>
            <div class="pl-bottle-meta">Apr 2022 · Better Sex</div>
            <div class="pl-bottle-player">
              <iframe
                src="https://open.spotify.com/embed/episode/0Ll8mexApKVOWvxQiUYNwo?utm_source=generator"
                width="100%"
                height="152"
                frameborder="0"
                allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
                loading="lazy"
                title="Better Sex Podcast — Pregnancy and Postpartum Challenges for Sex with Paula Leech"
              ></iframe>
            </div>
            <a href="https://open.spotify.com/episode/0Ll8mexApKVOWvxQiUYNwo" target="_blank" rel="noopener" class="pl-bottle-cork">Open on Spotify →</a>
          </div>

          <div class="pl-bottle">
            <span class="pl-bottle-audio-mark" aria-hidden="true">♪</span>
            <div class="pl-bottle-header">
              <span class="pl-bottle-kicker">No. III · Podcast</span>
            </div>
            <div class="pl-bottle-spacer"></div>
            <div class="pl-bottle-title">Embodiment &amp; the expression of sexuality.</div>
            <div class="pl-bottle-tincture">A conversation on what living in the body really asks of us.</div>
            <div class="pl-bottle-spacer"></div>
            <div class="pl-bottle-meta">Jul 2024 · 58 min</div>
            <div class="pl-bottle-player">
              <iframe
                src="https://open.spotify.com/embed/episode/0Py55ILnVqRoXEvP0eCmQY?utm_source=generator"
                width="100%"
                height="152"
                frameborder="0"
                allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
                loading="lazy"
                title="In This Body — The Importance of Embodiment in the Expression of Sexuality with Paula Leech"
              ></iframe>
            </div>
            <a href="https://open.spotify.com/episode/0Py55ILnVqRoXEvP0eCmQY" target="_blank" rel="noopener" class="pl-bottle-cork">Open on Spotify →</a>
          </div>

          <div class="pl-bottle">
            <span class="pl-bottle-audio-mark" aria-hidden="true">♪</span>
            <div class="pl-bottle-header">
              <span class="pl-bottle-kicker">No. IV · Podcast</span>
            </div>
            <div class="pl-bottle-spacer"></div>
            <div class="pl-bottle-title">From tension to trust: healing sexual anxiety.</div>
            <div class="pl-bottle-tincture">A practical conversation on how anxiety lodges in the body — and how it loosens.</div>
            <div class="pl-bottle-spacer"></div>
            <div class="pl-bottle-meta">Aug 2025 · Wise Body Sex Therapy</div>
            <div class="pl-bottle-player">
              <iframe
                src="https://embed.podcasts.apple.com/ca/podcast/from-tension-to-trust-paula-leech-on-healing-sexual-anxiety/id1833251163?i=1000721958902&theme=light"
                height="175"
                style="width:100%;overflow:hidden;border-radius:12px;"
                frameborder="0"
                sandbox="allow-forms allow-popups allow-same-origin allow-scripts allow-storage-access-by-user-activation allow-top-navigation-by-user-activation"
                allow="autoplay *; encrypted-media *; clipboard-write"
                loading="lazy"
                title="Wise Body Sex Therapy — From Tension to Trust with Paula Leech"
              ></iframe>
            </div>
            <a href="https://podcasts.apple.com/ca/podcast/from-tension-to-trust-paula-leech-on-healing-sexual-anxiety/id1833251163?i=1000721958902" target="_blank" rel="noopener" class="pl-bottle-cork">Open on Apple →</a>
          </div>
          </div>
          <button class="pl-shelf-prev" type="button" aria-label="Previous press item" data-target="press-shelf">←</button>
          <button class="pl-shelf-next" type="button" aria-label="Next press item" data-target="press-shelf">→</button>
        </div>
      </div>
    </div>
  </section>

  <!-- INLINE NEWSLETTER -->
  <section class="mx-auto max-w-[1400px] px-12 lg:px-20 mt-40 md:mt-56 pl-reveal">
    <div class="pl-newsletter-box" style="background: color-mix(in srgb, var(--color-honey) 35%, transparent); border-radius: 1rem;">
      <div class="pl-newsletter-copy">
        <p class="pl-label">The Newsletter</p>
        <h2 style="
          font-family: var(--font-display);
          font-style: italic;
          font-weight: 400;
          font-size: clamp(2rem, 4vw, 3.25rem);
          line-height: 1.05;
          letter-spacing: -0.02em;
          margin-top: 0.75rem;
        ">
          Occasional letters.
        </h2>
        <p class="mt-4 text-base" style="color: var(--color-ink-soft); max-width: 42ch; line-height: 1.6;">
          Writing on intimacy, anxiety, and the work in between &mdash; sent when I have something worth saying.
        </p>
      </div>
      <div class="pl-newsletter-form">
        <form data-newsletter="inline" class="flex flex-col gap-3" style="min-width: 0;" onsubmit="event.preventDefault(); event.target.querySelector('[data-msg]').textContent = 'Thanks. Will let you know when this is wired up.';">
          <input
            type="email"
            required
            name="email"
            placeholder="you@example.com"
            aria-label="Email address"
            class="px-5 py-4 rounded-full"
            style="background: var(--color-cream); border: 1px solid color-mix(in srgb, var(--color-ink) 25%, transparent); color: var(--color-ink); font-size: 1.05rem; width: 100%; min-width: 0; box-sizing: border-box;"
          />
          <button type="submit" class="pl-pill self-start" style="padding: 0.95rem 1.8rem; font-size: 0.95rem;">Subscribe</button>
          <span data-msg class="text-sm" style="color: var(--color-plum);"></span>
        </form>
      </div>
    </div>
  </section>

  <!-- BOOK CLOSING -->
  <section class="mx-auto max-w-[1400px] px-12 lg:px-20 mt-40 md:mt-56 mb-32 pl-reveal relative">
    <div class="pl-book-row items-stretch">
      <div class="pl-book-col-img">
        <div class="pl-parallax pl-book-frame h-full rounded-sm" data-speed="-0.05" style="background: #44754d; box-shadow: 0 30px 60px -20px rgba(42,56,24,0.3); overflow: hidden; min-height: calc(100% + 100px);">
          <img src={bookMockup.src} alt="Overcoming Anxiety in Sex and Relationships — book mockup" class="w-full h-full" style="object-fit: contain; object-position: center center; display: block; transform: scale(1.7); transform-origin: center center;" />
        </div>
      </div>
      <div class="pl-book-col-copy mt-10 md:mt-0">
        <span class="pl-label">The Book</span>
        <h2 style="
          font-family: var(--font-display);
          font-style: italic;
          font-weight: 400;
          font-size: clamp(2.25rem, 4.2vw, 3.75rem);
          line-height: 1.05;
          letter-spacing: -0.02em;
          margin-top: 0.75rem;
        ">
          Overcoming Anxiety<br/>in Sex and Relationships.
        </h2>
        <p class="mt-5" style="color: var(--color-plum); font-family: var(--font-mono); font-size: 0.78rem; letter-spacing: 0.14em; text-transform: uppercase;">
          A Comprehensive Guide for Individuals, Couples &amp; Therapists
        </p>
        <div class="pl-book-copy mt-8" style="color: var(--color-ink-soft); max-width: 54ch; line-height: 1.7;">
          <p>Learn how anxiety, stress, and pressure affect pleasure, connection, and sexual functioning. This book explores how anxiety shapes our physiology, understanding of ourselves, and our interactions with the world. Paula Leech guides readers to identify key sources of anxiety &mdash; from family and culture to relationship dynamics and sexual trauma.</p>
          <p>Offering practical tips and techniques, Leech encourages readers to rethink their definitions of sex, sexuality, and intimacy. Through mindfulness and embodiment exercises, she provides tools to release tension, work through sexual struggles, and reconnect with the body.</p>
          <p>Accessible and comprehensive, this guide is ideal for sex therapists and anyone facing anxiety-related challenges with themselves and/or their partners.</p>
        </div>
        <div class="mt-9">
          <a href="https://www.amazon.com/Overcoming-Anxiety-Sex-Relationships-Comprehensive/dp/1032438398" class="pl-pill" style="background: var(--color-blue);" target="_blank" rel="noopener">Buy the book →</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<script>
  // Press shelf — advance / rewind one card per click.
  document.querySelectorAll('.pl-shelf-next, .pl-shelf-prev').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.getAttribute('data-target');
      const shelf = id ? document.getElementById(id) : null;
      if (!shelf) return;
      const card = shelf.querySelector('.pl-bottle');
      const step = card ? card.getBoundingClientRect().width + 24 : 320;
      const dir = btn.classList.contains('pl-shelf-prev') ? -1 : 1;
      if (dir > 0) {
        const atEnd = shelf.scrollLeft + shelf.clientWidth >= shelf.scrollWidth - 8;
        shelf.scrollTo({ left: atEnd ? 0 : shelf.scrollLeft + step, behavior: 'smooth' });
      } else {
        const atStart = shelf.scrollLeft <= 8;
        shelf.scrollTo({ left: atStart ? shelf.scrollWidth : shelf.scrollLeft - step, behavior: 'smooth' });
      }
      updatePrev(shelf);
    });
  });

  // Hide the back button when at the start.
  function updatePrev(shelf) {
    const prev = document.querySelector('.pl-shelf-prev[data-target="' + shelf.id + '"]');
    if (!prev) return;
    prev.classList.toggle('is-hidden', shelf.scrollLeft <= 8);
  }
  document.querySelectorAll('.pl-apothecary-shelf--scroll').forEach((shelf) => {
    updatePrev(shelf);
    shelf.addEventListener('scroll', () => {
      updatePrev(shelf);
      shelf.classList.toggle('is-scrolled', shelf.scrollLeft > 8);
    }, { passive: true });
  });

  // Tarot cards — set font-size proportional to card width so all internal
  // em-based content scales together at every viewport size.
  function scaleTarotCards() {
    document.querySelectorAll('.pl-tarot-card').forEach((card) => {
      // Use offsetWidth (un-transformed) so tilt rotations don't affect em sizing
      const w = card.offsetWidth;
      card.style.fontSize = (w / 100) + 'px';
    });
  }
  scaleTarotCards();
  window.addEventListener('resize', scaleTarotCards);
  // Re-run after images load (card width may shift)
  document.querySelectorAll('.pl-tarot-card img').forEach((img) => {
    if (!img.complete) img.addEventListener('load', scaleTarotCards);
  });
  // iOS Safari: offsetWidth can be stale on first paint (web fonts / layout
  // still settling), which mis-sizes the em-driven content height. Re-run after
  // fonts settle, on the next two animation frames, and on orientation change.
  if (document.fonts && document.fonts.ready) {
    document.fonts.ready.then(scaleTarotCards);
  }
  requestAnimationFrame(() => requestAnimationFrame(scaleTarotCards));
  window.addEventListener('orientationchange', () => {
    requestAnimationFrame(() => requestAnimationFrame(scaleTarotCards));
  });
</script>
