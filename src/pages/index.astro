---
import Layout from '../layouts/Layout.astro';
import { asset } from '../lib/asset';
---
<Layout title="Paula Leech, LMFT, CST, CSTS — Sex Therapy, Training & Supervision">

  <!-- Hero -->
  <section class="relative max-w-6xl mx-auto px-6 pt-12 pb-24 overflow-hidden">
    <div class="blob" style="background:var(--color-peach); width:380px; height:380px; top:-60px; left:30%;"></div>
    <div class="blob" style="background:var(--color-sage); width:300px; height:300px; bottom:0; right:5%;"></div>

    <div class="relative grid md:grid-cols-2 gap-12 items-center">
      <div>
        <h1>Sex therapy, <em style="font-family:var(--font-script); font-style:normal; color:var(--color-clay); font-size:1.1em;">embodied</em>.</h1>
        <p class="mt-6 text-lg max-w-md">Untangling sexuality from shame, performance, and the silence we were raised in — for clients, supervisees, and the therapists training to do this work.</p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href="/book" class="btn">Book a Session</a>
          <a href="/trainings" class="btn" style="background:transparent; color:var(--color-ink); border:1px solid var(--color-ink);">View Trainings</a>
        </div>
      </div>
      <div class="relative">
        <div class="arch mx-auto" style="width:min(100%, 380px); aspect-ratio: 3/4;">
          <img src={asset("/images/img_16.jpeg")} alt="Paula Leech" class="w-full h-full object-cover" />
        </div>
      </div>
    </div>
  </section>

  <!-- Why I'm here -->
  <section class="max-w-3xl mx-auto px-6 py-20">
    <h2 class="text-center">Why I'm here</h2>
    <p class="mt-8">I truly love this work. I enjoy the challenging adventure of bringing relationships and individuals toward a greater sense of intimacy and a thriving, evolving connection — to self and other(s) — that can grow alongside them.</p>
    <p class="mt-4">I'm inspired by the inevitable transformation of the therapists themselves as they witness and become part of fantastic growth and change in their clients. I believe there is no limit to the knowledge we can gain from looking at the universe of people's lives and relationships; no end point to our curiosity if we let it lead.</p>
    <p class="mt-8 text-center"><a href="/about">Read more about Paula →</a></p>
  </section>

  <!-- Three doors -->
  <section class="relative max-w-6xl mx-auto px-6 py-20">
    <div class="blob" style="background:var(--color-blush); width:280px; height:280px; top:10%; right:-50px;"></div>
    <div class="grid md:grid-cols-3 gap-8 relative">
      {[
        {title:'Sex Therapy', desc:'1:1 and relational therapy for individuals and couples in MA + OR.', href:'/sex-therapy'},
        {title:'Trainings & Courses', desc:'Live trainings and self-paced courses for clinicians and the sexuality-curious.', href:'/trainings'},
        {title:'Supervision', desc:'AASECT certification supervision — individual and small group, worldwide.', href:'/supervision'},
      ].map(c => (
        <a href={c.href} class="block bg-[var(--color-cream-deep)]/50 hover:bg-[var(--color-cream-deep)] p-8 rounded-2xl no-underline transition" style="text-decoration:none;">
          <h3 style="margin:0;">{c.title}</h3>
          <p class="mt-3 text-sm">{c.desc}</p>
          <div class="mt-4 text-sm" style="color:var(--color-clay);">Explore →</div>
        </a>
      ))}
    </div>
  </section>

  <!-- Book teaser -->
  <section class="max-w-5xl mx-auto px-6 py-20 grid md:grid-cols-2 gap-10 items-center">
    <div class="text-center">
      <img src={asset("/images/img_27.jpg")} alt="Overcoming Anxiety in Sex and Relationships" class="max-w-xs mx-auto shadow-2xl" />
    </div>
    <div>
      <h2>Overcoming Anxiety in Sex and Relationships</h2>
      <p class="mt-4">Learn how anxiety, stress, and pressure affect pleasure, connection, and sexual functioning — and the practical tools to release tension and reconnect with the body.</p>
      <a href="/the-book" class="btn mt-6">Read the Book</a>
    </div>
  </section>

  <!-- Press strip -->
  <section class="bg-[var(--color-cream-deep)]/50 py-16">
    <div class="max-w-5xl mx-auto px-6 text-center">
      <h2>Featured in</h2>
      <p class="mt-2 text-sm uppercase tracking-widest" style="color:var(--color-clay);">Selected appearances</p>
      <ul class="mt-8 grid sm:grid-cols-2 gap-x-12 gap-y-3 text-sm list-none p-0 text-left">
        <li>• CNN Health</li>
        <li>• Women's Health</li>
        <li>• The Better Sex Podcast</li>
        <li>• In This Body Podcast</li>
        <li>• Sexvangelicals Podcast</li>
        <li>• Our Two Cents Podcast</li>
        <li>• The Natasha Helfer Podcast</li>
        <li>• Wise Body Sex Therapy Podcast</li>
      </ul>
      <a href="/press" class="btn mt-10" style="background:transparent; color:var(--color-ink); border:1px solid var(--color-ink);">All Press & Podcasts</a>
    </div>
  </section>

</Layout>
