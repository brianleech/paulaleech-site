---
import Layout from '../layouts/Layout.astro';
import armTouch from '../assets/illustrations/indiviualHeads.png';

const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');

// Acuity drawer for the free consult — same wiring as /contact
const ACUITY_OWNER = "16569176";
const CONSULT_SELECTOR = "94919917"; // New Client Consult
function acuityEmbedUrl(selector: string) {
  const params = new URLSearchParams({ owner: ACUITY_OWNER, ref: "embedded_booking" });
  if (selector) params.set("appointmentType", selector);
  return `https://app.acuityscheduling.com/schedule.php?${params.toString()}`;
}

const specializationCategories = [
  {
    label: "Identity & orientation",
    items: ["LGBTQ+", "Gender identity & sexual orientation"],
  },
  {
    label: "Desire & arousal",
    items: ["Low / no desire", "Desire discrepancy", "Difficulty reaching orgasm"],
  },
  {
    label: "Function",
    items: ["Erectile dysfunction", '"Premature" / early ejaculation', "Delayed ejaculation"],
  },
  {
    label: "Pain & the body",
    items: ["Vaginismus", "Sexual pain"],
  },
  {
    label: "Relational",
    items: ["Infidelity", "Non-monogamy", "Kink & BDSM"],
  },
  {
    label: "Behavior & history",
    items: ['"Sex addiction," porn "addiction" or compulsivity', "Sexual trauma"],
  },
  {
    label: "Across the lifespan",
    items: ["Developmental sexuality (children & teens)"],
  },
];
const specializationCoda = "And the things between, alongside, and underneath these.";
---
<Layout title="Sex Therapy — Paula Leech">

  <!-- HERO — full-bleed editorial header (matches About / Courses) -->
  <section class="pl-page-hero pl-page-hero--work pl-reveal">
    <div class="pl-page-hero-art pl-momentum" data-scroll="-0.12" data-resize="-0.3" aria-hidden="true">
      <img src={armTouch.src} alt="" class="pl-wwm-hero-img" />
    </div>
    <div class="pl-page-hero-inner">
      <p class="pl-label pl-page-hero-kicker">Sex Therapy</p>
      <h1 class="pl-page-hero-title">
        Work with<br/><em>me.</em>
      </h1>
      <p class="pl-page-hero-sub">
        Therapy for the parts of intimacy nobody handed us a script for.
        <span class="pl-page-hero-sub-meta">Portland in person · MA · OR · NY virtual.</span>
      </p>
    </div>
  </section>

  <!-- Long-form opening with sidebar logistics -->
  <section class="mx-auto max-w-[1400px] px-12 lg:px-20 mt-20 md:mt-28 pl-reveal">
    <div class="pl-grid items-start gap-y-12">
      <!-- Copy column -->
      <div class="col-span-12 lg:col-span-7 pl-essay">
        <div class="pl-essay-section">
          <span class="pl-essay-marker">I. The terrain</span>
          <p class="pl-essay-para pl-essay-para--lead">
            Our sexuality is completely and inextricably interwoven into all other facets of ourselves. It is something we get to know, and attempt to make sense of, our entire lives in the midst of silence and a sex-negative world. It is an immensely complex space that is particularly susceptible to shame, feelings of pressure/performance, and "shoulds." Yet sex is one of the ways — or even the primary way for some — that we express and receive love, both for ourselves and others. It IS connection, play, sharing, expression, and release.
          </p>
        </div>

        <span class="pl-essay-rule" aria-hidden="true"></span>

        <p class="pl-essay-pullquote">
          Therapy is a way to tap into the freedom and joy that comes with unraveling ourselves from shame, trauma, misinformation, repression and oppression.
        </p>

        <span class="pl-essay-rule" aria-hidden="true"></span>

        <div class="pl-essay-section">
          <span class="pl-essay-marker">II. The approach</span>
          <p class="pl-essay-para">
            Sex therapy can look very similar to more traditional models of therapy, but often with the added element of take-home experiences and exercises. It is a mind/body method of transformation and change, where the behavioral at-home component allows for clients to track their progress around sexual struggles concretely. The aim is to help clients reach the goals they came in with while also having expanded their sexual repertoire, connected with the evolving nuances of pleasure and eroticism, gained a sense of comfort communicating their sexual wants and needs, and cultivated a much deeper sense of connection to sensation, pleasure, self and other.
          </p>
        </div>
      </div>

      <!-- Logistics sidebar — stacked tiles + consult CTA -->
      <aside class="col-span-12 lg:col-span-5 lg:pl-16 pl-logistics-stack-wrap">
        <div class="pl-logistics-stack">
          <div class="pl-logistics-item pl-logistics-item--stack">
            <span class="pl-label">Rate</span>
            <p class="pl-logistics-value">$285<span style="font-size: 0.55em; color: var(--color-ink-soft); font-style: italic; margin-left: 0.25rem;">/ session</span></p>
            <p class="pl-logistics-meta">55-minute session · out-of-pocket</p>
          </div>
          <div class="pl-logistics-item pl-logistics-item--stack">
            <span class="pl-label">Where</span>
            <p class="pl-logistics-value"><em>Virtual</em> &amp; <em>Portland.</em></p>
            <p class="pl-logistics-meta">Telehealth for MA · OR · NY · In-person in PDX</p>
          </div>
          <div class="pl-logistics-item pl-logistics-item--stack">
            <span class="pl-label">Begin</span>
            <p class="pl-logistics-value"><em>Free</em> 15-min consult.</p>
            <p class="pl-logistics-meta">Phone or Zoom · no payment required</p>
          </div>
        </div>
        <div class="pl-logistics-cta">
          <button
            type="button"
            class="pl-primary-cta pl-drawer-trigger"
            data-drawer-target="consult"
          >
            Schedule a free consult
            <span aria-hidden="true" style="margin-left: 0.6rem;">→</span>
          </button>
        </div>
      </aside>
    </div>
  </section>

  <!-- Specializations -->
  <section class="mx-auto max-w-[1100px] px-12 lg:px-20 mt-28 md:mt-36 pl-reveal">
    <header class="pl-spec-header">
      <span class="pl-spec-rule" aria-hidden="true"></span>
      <h2 class="pl-spec-headline">
        <em>What I work with.</em>
      </h2>
      <span class="pl-spec-rule" aria-hidden="true"></span>
    </header>
    <ul class="pl-spec-clusters">
      {specializationCategories.map(cat => (
        <li class="pl-spec-cluster">
          <p class="pl-spec-cluster-label">{cat.label}</p>
          <ul class="pl-spec-chip-list">
            {cat.items.map(item => <li class="pl-spec-chip">{item}</li>)}
          </ul>
        </li>
      ))}
    </ul>
    <p class="pl-spec-note">{specializationCoda}</p>
  </section>

  <!-- Secondary: Supervision door -->
  <section class="mx-auto max-w-[1400px] px-12 lg:px-20 mt-32 md:mt-40 pl-reveal">
    <a href={`${BASE}/courses/`} class="pl-secondary-door pl-secondary-door--supervision">
      <div class="pl-secondary-door-text">
        <span class="pl-label">Are you a clinician?</span>
        <h2 class="pl-secondary-door-headline">
          <em>I also work with therapists.</em>
        </h2>
        <p class="pl-secondary-door-body">
          Group supervision for AASECT-track clinicians and those building toward sex-therapy practice. Plus trainings — closed cohorts, on-demand, and the occasional intensive.
        </p>
      </div>
      <span class="pl-secondary-door-cta">
        See supervision &amp; trainings
        <span class="pl-secondary-door-arrow" aria-hidden="true">→</span>
      </span>
    </a>
  </section>

  <!-- ============================================================
       Consult drawer (reuses the .pl-drawer pattern from /contact)
       ============================================================ -->
  <div class="pl-drawer" data-drawer-id="consult" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="drawer-title-consult">
    <div class="pl-drawer-backdrop" data-drawer-close></div>
    <aside class="pl-drawer-panel" tabindex="-1">
      <header class="pl-drawer-header">
        <div>
          <p class="pl-label" style="margin-bottom: 0.35rem;">Schedule a consult</p>
          <h3 id="drawer-title-consult" style="
            font-family: var(--font-display);
            font-weight: 500;
            font-style: italic;
            font-size: clamp(1.4rem, 2.4vw, 1.85rem);
            line-height: 1.15;
            letter-spacing: -0.015em;
            color: var(--color-ink);
            margin: 0;
          ">Schedule a free consult</h3>
          <p style="
            color: var(--color-ink-soft);
            font-size: 0.95rem;
            margin: 0.4rem 0 0;
          ">15 minutes · phone or Zoom · no payment required</p>
        </div>
        <button type="button" class="pl-drawer-close" data-drawer-close aria-label="Close booking">
          <span aria-hidden="true">×</span>
        </button>
      </header>
      <div class="pl-drawer-body">
        <iframe
          data-src={acuityEmbedUrl(CONSULT_SELECTOR)}
          title="Schedule a free consult"
          width="100%"
          height="100%"
          frameborder="0"
          allowtransparency="true"
          loading="lazy"
          style="border: 0; width: 100%; height: 100%; min-height: 600px; background: white;"
        ></iframe>
      </div>
    </aside>
  </div>

  <!-- Acuity embed helper -->
  <script src="https://embed.acuityscheduling.com/js/embed.js" type="text/javascript"></script>

  <!-- Drawer logic (same pattern as /contact) -->
  <script>
    (function () {
      const drawers = new Map();
      document.querySelectorAll('.pl-drawer').forEach(d => {
        const id = d.getAttribute('data-drawer-id');
        if (id) drawers.set(id, d);
      });
      let lastFocus = null;

      function openDrawer(id) {
        const d = drawers.get(id);
        if (!d) return;
        // Track booking intent (Umami custom event). Safe no-op if script absent.
        if (window.umami) window.umami.track('booking-open', { service: id, page: 'work-with-paula' });
        lastFocus = document.activeElement;
        const iframe = d.querySelector('iframe[data-src]');
        if (iframe && !iframe.src) iframe.src = iframe.getAttribute('data-src');
        d.setAttribute('aria-hidden', 'false');
        d.classList.add('is-open');
        document.body.style.overflow = 'hidden';
        const panel = d.querySelector('.pl-drawer-panel');
        if (panel) panel.focus();
      }

      function closeDrawer(d) {
        d.setAttribute('aria-hidden', 'true');
        d.classList.remove('is-open');
        document.body.style.overflow = '';
        if (lastFocus && typeof lastFocus.focus === 'function') lastFocus.focus();
      }

      function closeAll() { drawers.forEach(closeDrawer); }

      document.querySelectorAll('.pl-drawer-trigger').forEach(btn => {
        btn.addEventListener('click', () => {
          const id = btn.getAttribute('data-drawer-target');
          if (id) openDrawer(id);
        });
      });
      document.querySelectorAll('[data-drawer-close]').forEach(el => {
        el.addEventListener('click', e => {
          const d = e.target.closest('.pl-drawer');
          if (d) closeDrawer(d);
        });
      });
      document.addEventListener('keydown', e => {
        if (e.key === 'Escape') closeAll();
      });
    })();
  </script>

</Layout>

<style>
  /* Local override — make the work-with-me hero artwork much larger than the
     global .pl-page-hero--work default (43% / 576px). Page-scoped so other
     pages using --work (supervision) are unaffected. */
  .pl-page-hero--work .pl-page-hero-art {
    width: 64% !important;
    max-width: 880px !important;
    top: 50% !important;
    right: calc(max(0px, (100vw - 1400px) / 2) + 5rem) !important;
    transform: translateY(-50%) !important;
    -webkit-mask-image: none !important;
            mask-image: none !important;
    /* Source PNG has ~23% transparent padding on the right — let the img
       overflow the container so the visible right edge aligns with the
       Email button line. */
    overflow: visible !important;
  }
  /* Custom keyframe — bakes the +23% translateX shift into both endpoints
     so the breathing motion doesn't snap the artwork back to center. */
  .pl-wwm-hero-img {
    animation: pl-wwm-hero-breathe 13s ease-in-out infinite;
    will-change: transform;
  }
  @keyframes pl-wwm-hero-breathe {
    0%, 100% { transform: translate(23%, 0)        rotate(0deg); }
    50%      { transform: translate(calc(23% + 6px), -8px) rotate(1deg); }
  }

  /* ============================================================
     Essay — lettered section markers, hairline rules, drop cap
     ============================================================ */
  .pl-essay {
    /* No vertical rhythm overrides; section spacing handles it */
  }
  .pl-essay-section + .pl-essay-section { margin-top: 0; }
  .pl-essay-marker {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-plum);
    margin-bottom: 1rem;
  }
  .pl-essay-para {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.15rem, 1.5vw, 1.35rem);
    line-height: 1.65;
    color: var(--color-ink);
    margin: 0;
  }
  /* Drop cap on the lead paragraph */
  .pl-essay-para--lead::first-letter {
    font-family: var(--font-display);
    font-weight: 500;
    font-style: italic;
    color: var(--color-plum);
    float: left;
    font-size: 4.5rem;
    line-height: 0.85;
    padding: 0.4rem 0.75rem 0 0;
    margin-top: 0.2rem;
  }
  .pl-essay-rule {
    display: block;
    width: 100%;
    height: 1px;
    background: color-mix(in srgb, var(--color-ink) 18%, transparent);
    margin: 2.75rem 0;
  }
  .pl-essay-pullquote {
    font-family: var(--font-display);
    font-weight: 400;
    font-style: italic;
    font-size: clamp(1.5rem, 2.1vw, 1.85rem);
    line-height: 1.4;
    color: var(--color-plum);
    letter-spacing: -0.015em;
    margin: 0;
    padding: 0 0.5rem;
    /* Slight hanging punctuation feel */
    text-indent: -0.4rem;
  }

  /* ============================================================
     Specializations — categorized chip clusters (variant 1)
     ============================================================ */
  .pl-spec-clusters {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 2.5rem 3rem;
  }
  .pl-spec-cluster {
    margin: 0;
  }
  .pl-spec-cluster-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-plum);
    margin: 0 0 1rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid color-mix(in srgb, var(--color-ink) 25%, transparent);
  }
  .pl-spec-chip-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .pl-spec-chip {
    font-family: var(--font-display);
    font-size: 0.95rem;
    line-height: 1.3;
    color: var(--color-ink);
    padding: 0.4rem 0.85rem;
    background: color-mix(in srgb, var(--color-ink) 5%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-ink) 14%, transparent);
    border-radius: 999px;
  }

  /* ============================================================
     Specializations — centered editorial list w/ rules + 2-col grid
     ============================================================ */
  .pl-spec-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }
  .pl-spec-rule {
    display: block;
    width: 3rem;
    height: 1px;
    background: color-mix(in srgb, var(--color-ink) 30%, transparent);
  }
  .pl-spec-headline {
    font-family: var(--font-display);
    font-weight: 500;
    font-style: italic;
    font-size: clamp(2rem, 3.6vw, 3rem);
    line-height: 1;
    letter-spacing: -0.025em;
    color: var(--color-ink);
    margin: 0;
  }
  .pl-spec-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    column-gap: 4rem;
    row-gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .pl-spec-item {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.05rem, 1.3vw, 1.2rem);
    line-height: 1.5;
    color: var(--color-ink);
    padding: 1.1rem 0;
    border-bottom: 1px solid color-mix(in srgb, var(--color-ink) 12%, transparent);
  }
  .pl-spec-item--coda {
    grid-column: 1 / -1;
    font-style: italic;
    color: var(--color-ink-soft);
    text-align: center;
    padding: 2rem 0 0.4rem;
    border-bottom: none;
    font-size: clamp(1rem, 1.15vw, 1.1rem);
  }
  .pl-spec-note {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1rem, 1.15vw, 1.1rem);
    line-height: 1.6;
    color: var(--color-ink-soft);
    text-align: center;
    margin: 2.5rem auto 0;
    max-width: 50ch;
  }
  @media (max-width: 700px) {
    .pl-spec-list { grid-template-columns: 1fr; }
    .pl-spec-header { gap: 1rem; }
    .pl-spec-rule { width: 2rem; }
  }

  /* ============================================================
     Logistics row — three columns, editorial label/value/meta
     ============================================================ */
  .pl-logistics {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    align-items: stretch;
    border-top: 1px solid color-mix(in srgb, var(--color-ink) 18%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--color-ink) 18%, transparent);
  }
  .pl-logistics-item {
    padding: 2.75rem 2rem;
    text-align: center;
  }
  .pl-logistics-item + .pl-logistics-item {
    border-left: 1px solid color-mix(in srgb, var(--color-ink) 18%, transparent);
  }
  .pl-logistics-value {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(2rem, 3.2vw, 2.75rem);
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: var(--color-ink);
    margin: 0.6rem 0 0.65rem;
  }
  .pl-logistics-value em {
    font-style: italic;
    font-weight: 400;
  }
  .pl-logistics-meta {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-ink) 50%, transparent);
    margin: 0;
    line-height: 1.5;
  }
  @media (max-width: 800px) {
    .pl-logistics { grid-template-columns: 1fr; }
    .pl-logistics-item + .pl-logistics-item {
      border-left: none;
      border-top: 1px solid color-mix(in srgb, var(--color-ink) 18%, transparent);
    }
    .pl-logistics-item { padding: 2rem 1rem; }
  }

  /* Hero sub — meta line (location/scope) on its own row, smaller + muted */
  .pl-page-hero-sub-meta {
    display: block;
    margin-top: 1.25rem;
    font-family: var(--font-mono);
    font-style: normal;
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-plum);
  }

  /* Stacked variant — used as a sidebar next to the intro copy.
     Mirrors the bottom-of-page row, rotated: vertical rules on the L/R of the
     whole column, horizontal divider between each cell. */
  .pl-logistics-stack {
    display: flex;
    flex-direction: column;
    border-left: 1px solid color-mix(in srgb, var(--color-ink) 18%, transparent);
    border-right: 1px solid color-mix(in srgb, var(--color-ink) 18%, transparent);
    padding-top: 0;
  }
  .pl-logistics-item--stack {
    padding: 3.25rem 1.75rem;
    text-align: center;
    /* Reset the grid variant's left-border rule */
    border-left: none !important;
  }
  .pl-logistics-item--stack + .pl-logistics-item--stack {
    border-left: none !important;
    border-top: 1px solid color-mix(in srgb, var(--color-ink) 18%, transparent);
  }
  .pl-logistics-value {
    /* Slight breathing room inside each tile in the sidebar variant */
  }
  .pl-logistics-item--stack .pl-logistics-value {
    margin: 1rem 0 1rem;
  }
  .pl-logistics-item--stack .pl-logistics-meta {
    margin-top: 0.25rem;
  }
  .pl-logistics-cta {
    display: flex;
    justify-content: center;
    margin-top: 2.5rem;
  }
  .pl-logistics-cta .pl-primary-cta {
    /* Sidebar context — slightly smaller than the full-width center CTA */
    font-size: clamp(1.1rem, 1.5vw, 1.35rem);
    padding: 1.05rem 1.9rem;
  }

  /* Primary CTA — big editorial button */
  .pl-primary-cta-wrap {
    display: flex;
    justify-content: center;
    margin-top: 3rem;
  }
  .pl-primary-cta {
    appearance: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(1.3rem, 1.9vw, 1.65rem);
    line-height: 1;
    color: var(--color-cream);
    background: var(--color-ink);
    padding: 1.3rem 2.4rem;
    border-radius: 999px;
    transition: background 0.25s ease, transform 0.25s ease, padding 0.25s ease;
  }
  .pl-primary-cta:hover {
    background: var(--color-plum);
    transform: translateY(-1px);
    padding-right: 2.7rem;
  }

  /* ============================================================
     Secondary door — supervision
     ============================================================ */
  .pl-secondary-door {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 3rem;
    padding: 3rem 2.5rem;
    background: color-mix(in srgb, var(--color-honey) 28%, transparent);
    border-radius: 1rem;
    text-decoration: none;
    color: inherit;
    transition: background 0.3s ease, transform 0.3s ease;
  }
  .pl-secondary-door:hover {
    background: color-mix(in srgb, var(--color-honey) 45%, transparent);
    transform: translateY(-2px);
  }
  .pl-secondary-door-text { max-width: 65ch; }
  .pl-secondary-door-headline {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.6rem, 2.8vw, 2.4rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin: 0.4rem 0 0.8rem;
  }
  .pl-secondary-door-headline em {
    font-style: italic;
    font-weight: 400;
  }
  .pl-secondary-door-body {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.2vw, 1.15rem);
    line-height: 1.55;
    color: var(--color-ink-soft);
    margin: 0;
    max-width: 60ch;
  }
  .pl-secondary-door-cta {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(1.1rem, 1.5vw, 1.3rem);
    color: var(--color-plum);
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    border-bottom: 1px solid color-mix(in srgb, var(--color-plum) 30%, transparent);
    padding-bottom: 0.25rem;
    flex-shrink: 0;
    white-space: nowrap;
