---
import Layout from '../layouts/Layout.astro';
import individualHeads from '../assets/illustrations/indiviualHeads.png';
import groupHeads from '../assets/illustrations/Group_Heads.png';
import twoHeads from '../assets/illustrations/twoHeads.png';

const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');

// Acuity drawer wiring — reuse the Work With Me consult selector until
// Paula tells us a dedicated supervision intake ID exists.
const ACUITY_OWNER = "16569176";
const CONSULT_SELECTOR = "94967060";          // Supervisor-of-supervisors consult
const IND_CONSULT_SELECTOR = "94965894";      // Individual supervision — new supervisee free consult
const IND_BOOK_SELECTOR = "7998756";          // Individual supervision — existing supervisee booking
const GROUP_SELECTOR = "7998753";             // Online group supervision signup
function acuityEmbedUrl(selector: string) {
  const params = new URLSearchParams({ owner: ACUITY_OWNER, ref: "embedded_booking" });
  if (selector) params.set("appointmentType", selector);
  return `https://app.acuityscheduling.com/schedule.php?${params.toString()}`;
}
---
<Layout title="Supervision — Paula Leech, LMFT, CST, CSTS">

  <!-- HERO — full-bleed editorial header, matches About / Courses / Work With Me -->
  <section class="pl-page-hero pl-page-hero--work pl-reveal">
    <div class="pl-page-hero-art pl-momentum" data-scroll="-0.1" data-resize="-0.3" aria-hidden="true">
      <img src={individualHeads.src} alt="" class="pl-float-slow-rev" />
    </div>
    <div class="pl-page-hero-inner">
      <p class="pl-label pl-page-hero-kicker">Clinical Supervision</p>
      <h1 class="pl-page-hero-title">
        Become a<br/><em>sex therapist.</em>
      </h1>
      <p class="pl-page-hero-sub">
        AASECT-accumulating supervision for clinicians building toward certification — and the supervisors who train them next.
        <span class="pl-page-hero-sub-meta">Virtual · worldwide · individual &amp; group</span>
      </p>
    </div>
  </section>

  <!-- ============================================================
       SECTION 1 — Individual Supervision (forest green block + MirroredHeads)
       ============================================================ -->
  <section class="pl-sup-block pl-sup-block--green pl-reveal" id="individual">
    <div class="pl-sup-block-art" aria-hidden="true">
      <img src={individualHeads.src} alt="" />
    </div>
    <div class="pl-sup-block-body">
      <span class="pl-label pl-sup-block-kicker">No. I</span>
      <h2 class="pl-sup-block-title"><em>Individual</em> Supervision</h2>
      <p class="pl-sup-block-lead">
        Sex therapist supervisees are required to collect 50 hours of supervision to apply for AASECT certification. I meet with supervisees in person, by phone, or over video — most often for an hour, occasionally for 90 minutes.
      </p>
      <p class="pl-sup-block-para">
        Together, we go beyond technical skill. We work on:
      </p>
      <ol class="pl-sup-list">
        <li><span class="pl-sup-list-num">01</span><span>Assessing strengths and growth edges, both at the start and as they shift.</span></li>
        <li><span class="pl-sup-list-num">02</span><span>Developing a clinical voice that's synchronous with who you are — personally and professionally — today.</span></li>
        <li><span class="pl-sup-list-num">03</span><span>Illuminating and working through the emotional reactions that surface during sex therapy work.</span></li>
        <li><span class="pl-sup-list-num">04</span><span>Building or strengthening the systemic framework needed for couples and family work.</span></li>
        <li><span class="pl-sup-list-num">05</span><span>Navigating the AASECT certification process, if that's a path you choose.</span></li>
      </ol>
      <div class="pl-sup-cta-pair">
        <div class="pl-sup-cta-card">
          <span class="pl-label">New supervisee</span>
          <p class="pl-sup-cta-desc">Wondering if we're a fit?</p>
          <button type="button" class="pl-primary-cta pl-primary-cta--invert pl-drawer-trigger" data-drawer-target="sup-ind-consult">
            Free consult
            <span aria-hidden="true" style="margin-left: 0.6rem;">→</span>
          </button>
        </div>
        <div class="pl-sup-cta-card">
          <span class="pl-label">Already supervising with me?</span>
          <p class="pl-sup-cta-desc">Book your next session.</p>
          <button type="button" class="pl-primary-cta pl-primary-cta--ghost pl-drawer-trigger" data-drawer-target="sup-ind-book">
            Book a session
            <span aria-hidden="true" style="margin-left: 0.6rem;">→</span>
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 2 — Online Group Supervision (blush block + GroupSupervisionHeads)
       Art on LEFT this time for alternation
       ============================================================ -->
  <section class="pl-sup-block pl-sup-block--blush pl-sup-block--reverse pl-reveal" id="group">
    <div class="pl-sup-block-art" aria-hidden="true">
      <img src={groupHeads.src} alt="" />
    </div>
    <div class="pl-sup-block-body">
      <span class="pl-label pl-sup-block-kicker">No. II</span>
      <h2 class="pl-sup-block-title"><em>Online Group</em> Supervision</h2>
      <p class="pl-sup-block-lead">
        Held exclusively over Zoom. I don't run a cohort model — meaning you'll be exposed to a wide variety of cases from therapists practicing with diverse populations around the world.
      </p>
      <p class="pl-sup-block-para">
        Groups are limited, so spots fill up — sign up in advance. AASECT requires 30 minutes per group member, so meeting length varies with registration. I give as much advance notice as possible so scheduling stays easy.
      </p>
      <p class="pl-sup-block-para">
        You don't need a case ready for every meeting. Other members often bring cases, plus general topics or self-of-therapist questions that surface in conversation. Group supervision can account for half — up to 25 — of the 50 required hours.
      </p>
      <div class="pl-sup-block-cta">
        <button type="button" class="pl-primary-cta pl-drawer-trigger" data-drawer-target="sup-group">
          Join a group
          <span aria-hidden="true" style="margin-left: 0.6rem;">→</span>
        </button>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 3 — Supervision of Supervisors (wine block + paired heads)
       ============================================================ -->
  <section class="pl-sup-block pl-sup-block--wine pl-reveal" id="supervisor">
    <div class="pl-sup-block-art" aria-hidden="true">
      <img src={twoHeads.src} alt="" />
    </div>
    <div class="pl-sup-block-body">
      <span class="pl-label pl-sup-block-kicker">No. III</span>
      <h2 class="pl-sup-block-title">Supervision to become a <em>sex therapy supervisor.</em></h2>
      <p class="pl-sup-block-lead">
        Two years after certification and active practice as a sex therapist or counselor, you're eligible to begin training to become a supervisor yourself. The path requires 30 hours of supervision-of-supervision (group accounting for no more than half) and active supervision of at least two supervisees.
      </p>
      <p class="pl-sup-block-para">
        In our first meeting I walk prospective supervisors through the requirements, how they differ from general certification, and where to begin finding supervisees. Through our time together we'll:
      </p>
      <ol class="pl-sup-list">
        <li><span class="pl-sup-list-num">01</span><span>Develop a thorough understanding of the supervisor role — versus therapist or mentor — including boundary setting, expectations, and education.</span></li>
        <li><span class="pl-sup-list-num">02</span><span>Co-facilitate group supervision of prospective sex therapy applicants, with a critical eye to group process and creative ways of structuring the hour around members' goals.</span></li>
        <li><span class="pl-sup-list-num">03</span><span>Develop your unique supervisor voice — aligned with your philosophy and synchronous with who you are today.</span></li>
        <li><span class="pl-sup-list-num">04</span><span>Look at best practice for setting supervisees up for success: the supervision handbook, AASECT ethics, current certification requirements, and the changes happening inside the organization.</span></li>
      </ol>
      <div class="pl-sup-block-cta">
        <button type="button" class="pl-primary-cta pl-primary-cta--invert pl-drawer-trigger" data-drawer-target="sup-consult">
          Let's talk
          <span aria-hidden="true" style="margin-left: 0.6rem;">→</span>
        </button>
      </div>
    </div>
  </section>

  <!-- ============================================================
       Consult drawer
       ============================================================ -->
  <div class="pl-drawer" data-drawer-id="sup-consult" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="drawer-title-sup-consult">
    <div class="pl-drawer-backdrop" data-drawer-close></div>
    <aside class="pl-drawer-panel" tabindex="-1">
      <header class="pl-drawer-header">
        <div>
          <p class="pl-label" style="margin-bottom: 0.35rem;">Schedule a consult</p>
          <h3 id="drawer-title-sup-consult" style="
            font-family: var(--font-display);
            font-weight: 500;
            font-style: italic;
            font-size: clamp(1.4rem, 2.4vw, 1.85rem);
            line-height: 1.15;
            letter-spacing: -0.015em;
            color: var(--color-ink);
            margin: 0;
          ">Supervision consult</h3>
          <p style="color: var(--color-ink-soft); font-size: 0.95rem; margin: 0.4rem 0 0;">
            15 minutes · phone or Zoom · for prospective supervisees and supervisors-in-training
          </p>
        </div>
        <button type="button" class="pl-drawer-close" data-drawer-close aria-label="Close booking">
          <span aria-hidden="true">×</span>
        </button>
      </header>
      <div class="pl-drawer-body">
        <iframe
          data-src={acuityEmbedUrl(CONSULT_SELECTOR)}
          title="Schedule a supervision consult"
          width="100%"
          height="100%"
          frameborder="0"
          allowtransparency="true"
          loading="lazy"
          style="border: 0; width: 100%; height: 100%; min-height: 600px; background: white;"
        ></iframe>
      </div>
    </aside>
  </div>

  <!-- ============================================================
       Individual supervision drawers — new consult + existing booking
       ============================================================ -->
  <div class="pl-drawer" data-drawer-id="sup-ind-consult" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="drawer-title-sup-ind-consult">
    <div class="pl-drawer-backdrop" data-drawer-close></div>
    <aside class="pl-drawer-panel" tabindex="-1">
      <header class="pl-drawer-header">
        <div>
          <p class="pl-label" style="margin-bottom: 0.35rem;">Individual supervision</p>
          <h3 id="drawer-title-sup-ind-consult" style="
            font-family: var(--font-display); font-weight: 500; font-style: italic;
            font-size: clamp(1.4rem, 2.4vw, 1.85rem); line-height: 1.15;
            letter-spacing: -0.015em; color: var(--color-ink); margin: 0;
          ">New supervisee — free consult</h3>
          <p style="color: var(--color-ink-soft); font-size: 0.95rem; margin: 0.4rem 0 0;">
            15 minutes · phone or Zoom · no payment required
          </p>
        </div>
        <button type="button" class="pl-drawer-close" data-drawer-close aria-label="Close booking">
          <span aria-hidden="true">×</span>
        </button>
      </header>
      <div class="pl-drawer-body">
        <iframe
          data-src={acuityEmbedUrl(IND_CONSULT_SELECTOR)}
          title="Schedule a free supervision consult"
          width="100%" height="100%" frameborder="0" allowtransparency="true" loading="lazy"
          style="border: 0; width: 100%; height: 100%; min-height: 600px; background: white;"
        ></iframe>
      </div>
    </aside>
  </div>

  <div class="pl-drawer" data-drawer-id="sup-ind-book" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="drawer-title-sup-ind-book">
    <div class="pl-drawer-backdrop" data-drawer-close></div>
    <aside class="pl-drawer-panel" tabindex="-1">
      <header class="pl-drawer-header">
        <div>
          <p class="pl-label" style="margin-bottom: 0.35rem;">Individual supervision</p>
          <h3 id="drawer-title-sup-ind-book" style="
            font-family: var(--font-display); font-weight: 500; font-style: italic;
            font-size: clamp(1.4rem, 2.4vw, 1.85rem); line-height: 1.15;
            letter-spacing: -0.015em; color: var(--color-ink); margin: 0;
          ">Book a supervision session</h3>
          <p style="color: var(--color-ink-soft); font-size: 0.95rem; margin: 0.4rem 0 0;">
            For active supervisees · in person, phone, or Zoom
          </p>
        </div>
        <button type="button" class="pl-drawer-close" data-drawer-close aria-label="Close booking">
          <span aria-hidden="true">×</span>
        </button>
      </header>
      <div class="pl-drawer-body">
        <iframe
          data-src={acuityEmbedUrl(IND_BOOK_SELECTOR)}
          title="Book a supervision session"
          width="100%" height="100%" frameborder="0" allowtransparency="true" loading="lazy"
          style="border: 0; width: 100%; height: 100%; min-height: 600px; background: white;"
        ></iframe>
      </div>
    </aside>
  </div>

  <!-- ============================================================
       Group supervision drawer
       ============================================================ -->
  <div class="pl-drawer" data-drawer-id="sup-group" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="drawer-title-sup-group">
    <div class="pl-drawer-backdrop" data-drawer-close></div>
    <aside class="pl-drawer-panel" tabindex="-1">
      <header class="pl-drawer-header">
        <div>
          <p class="pl-label" style="margin-bottom: 0.35rem;">Group supervision</p>
          <h3 id="drawer-title-sup-group" style="
            font-family: var(--font-display);
            font-weight: 500;
            font-style: italic;
            font-size: clamp(1.4rem, 2.4vw, 1.85rem);
            line-height: 1.15;
            letter-spacing: -0.015em;
            color: var(--color-ink);
            margin: 0;
          ">Join an online group</h3>
          <p style="color: var(--color-ink-soft); font-size: 0.95rem; margin: 0.4rem 0 0;">
            Zoom · groups are limited · counts toward AASECT certification hours
          </p>
        </div>
        <button type="button" class="pl-drawer-close" data-drawer-close aria-label="Close booking">
          <span aria-hidden="true">×</span>
        </button>
      </header>
      <div class="pl-drawer-body">
        <iframe
          data-src={acuityEmbedUrl(GROUP_SELECTOR)}
          title="Sign up for group supervision"
          width="100%"
          height="100%"
          frameborder="0"
          allowtransparency="true"
          loading="lazy"
          style="border: 0; width: 100%; height: 100%; min-height: 600px; background: white;"
        ></iframe>
      </div>
    </aside>
  </div>

  <script src="https://embed.acuityscheduling.com/js/embed.js" type="text/javascript"></script>
  <script is:inline>
    (function () {
      const drawers = new Map();
      document.querySelectorAll('.pl-drawer').forEach(d => {
        const id = d.getAttribute('data-drawer-id');
        if (id) drawers.set(id, d);
      });
      let lastFocus = null;

      function openDrawer(id) {
        const d = drawers.get(id);
        if (!d) return;
        lastFocus = document.activeElement;
        const iframe = d.querySelector('iframe[data-src]');
        if (iframe && !iframe.src) iframe.src = iframe.getAttribute('data-src');
        d.setAttribute('aria-hidden', 'false');
        d.classList.add('is-open');
        document.body.style.overflow = 'hidden';
        const panel = d.querySelector('.pl-drawer-panel');
        if (panel) panel.focus();
      }
      function closeDrawer(d) {
        d.setAttribute('aria-hidden', 'true');
        d.classList.remove('is-open');
        document.body.style.overflow = '';
        if (lastFocus && typeof lastFocus.focus === 'function') lastFocus.focus();
      }
      function closeAll() { drawers.forEach(closeDrawer); }

      document.querySelectorAll('.pl-drawer-trigger').forEach(btn => {
        btn.addEventListener('click', () => {
          const id = btn.getAttribute('data-drawer-target');
          if (id) openDrawer(id);
        });
      });
      document.querySelectorAll('[data-drawer-close]').forEach(el => {
        el.addEventListener('click', e => {
          const d = e.target.closest('.pl-drawer');
          if (d) closeDrawer(d);
        });
      });
      document.addEventListener('keydown', e => {
        if (e.key === 'Escape') closeAll();
      });
    })();
  </script>

</Layout>

<style>
  /* ============================================================
     Supervision bold blocks — edge-to-edge slabs of color
     with a watercolor head illustration on one side
     ============================================================ */
  .pl-sup-block {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: stretch;
    margin-top: 0;
  }
  .pl-sup-block:first-of-type { margin-top: 6rem; }
  .pl-sup-block-art {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    min-height: 640px;
  }
  .pl-sup-block-art img {
    width: 100%;
    max-width: none;
    height: auto;
    display: block;
  }
  .pl-sup-block-body {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 5rem clamp(2.5rem, 6vw, 5rem);
    max-width: 720px;
  }
  .pl-sup-block-kicker {
    color: var(--color-plum);
    margin-bottom: 1.25rem;
  }
  .pl-sup-block-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(2.2rem, 4.2vw, 3.4rem);
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--color-ink);
    margin: 0 0 1.75rem;
  }
  .pl-sup-block-title em { font-style: italic; font-weight: 400; }
  .pl-sup-block-lead {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.15rem, 1.5vw, 1.35rem);
    line-height: 1.55;
    color: var(--color-ink);
    margin: 0 0 1.25rem;
  }
  .pl-sup-block-para {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1rem, 1.25vw, 1.15rem);
    line-height: 1.65;
    color: var(--color-ink);
    margin: 0 0 1rem;
  }
  .pl-sup-list {
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .pl-sup-list li {
    display: grid;
    grid-template-columns: 2rem 1fr;
    gap: 0.5rem 0.85rem;
    align-items: baseline;
    font-family: var(--font-display);
    font-size: clamp(0.95rem, 1.15vw, 1.05rem);
    line-height: 1.55;
    color: var(--color-ink);
  }
  .pl-sup-list-num {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    color: var(--color-plum);
    padding-top: 0.2rem;
  }
  .pl-sup-block-cta { margin-top: 2rem; }
  .pl-sup-block-cta--dual {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1rem;
    align-items: center;
  }

  /* Paired CTA cards — two side-by-side mini panels, each with kicker label,
     one-line description, and a button. */
  .pl-sup-cta-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid color-mix(in srgb, var(--color-ink) 18%, transparent);
  }
  .pl-sup-cta-card {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    align-items: flex-start;
  }
  .pl-sup-cta-card .pl-label {
    color: var(--color-plum);
  }
  .pl-sup-cta-desc {
    font-family: var(--font-display);
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--color-ink-soft);
    margin: 0 0 0.4rem;
  }
  @media (max-width: 720px) {
    .pl-sup-cta-pair { grid-template-columns: 1fr; gap: 1.75rem; }
  }

  .pl-primary-cta--ghost {
    background: transparent;
    color: var(--color-ink);
    border: 1px solid color-mix(in srgb, var(--color-ink) 35%, transparent);
  }
  .pl-primary-cta--ghost:hover {
    background: color-mix(in srgb, var(--color-ink) 6%, transparent);
    color: var(--color-ink);
  }

  /* Reversed (text on left, art on right) — flips column positions.
     Text body hugs the right edge of its column so it butts up against the art. */
  .pl-sup-block--reverse .pl-sup-block-art { order: 2; }
  .pl-sup-block--reverse .pl-sup-block-body { order: 1; margin-left: auto; margin-right: 0; }

  /* Kill footer top-margin AND the newsletter band's own top-padding on pages
     that end in a full-bleed .pl-sup-block, so the dark slab butts directly
     up against the "Occasional letters" headline with zero gap. */
  :global(body:has(.pl-sup-block) footer.mt-40) {
    margin-top: 0 !important;
  }
  :global(body:has(.pl-sup-block) footer.mt-40 > div:first-child) {
    padding-top: 0 !important;
  }

  /* Color variants — art on color block, body on cream.
     The section itself ALSO gets the art color as its background, so on
     large screens (where .pl-sup-block-body is capped at max-width: 720px)
     the area outside the cream text panel is filled with the illustration's
     background color, not blank cream. */
  .pl-sup-block--green { background: #1f3320; }
  .pl-sup-block--green .pl-sup-block-art { background: #1f3320; }
  .pl-sup-block--green .pl-sup-block-body { background: var(--color-cream); }
  .pl-sup-block--blush { background: #e8d5cb; }
  .pl-sup-block--blush .pl-sup-block-art { background: #e8d5cb; }
  .pl-sup-block--blush .pl-sup-block-body { background: var(--color-cream); }
  .pl-sup-block--wine  { background: #2a0f10; }
  .pl-sup-block--wine  .pl-sup-block-art { background: #2a0f10; }
  .pl-sup-block--wine  .pl-sup-block-body { background: var(--color-cream); }

  /* Section 3 — facing pair of heads */
  .pl-sup-block-art--pair { position: relative; }
  .pl-sup-pair-head {
    position: absolute;
    width: 38%;
    max-width: 260px;
    height: auto;
    opacity: 0.85;
    filter: brightness(0.95);
  }
  .pl-sup-pair-head--rose {
    left: 14%;
    top: 50%;
    transform: translateY(-50%);
  }
  .pl-sup-pair-head--sage {
    right: 14%;
    top: 50%;
    transform: translateY(-50%) scaleX(-1);
  }

  /* Inverted CTA — for visibility on art blocks if ever needed (kept for parity) */
  .pl-primary-cta--invert { background: var(--color-ink); color: var(--color-cream); }

  /* Solidify the sticky header backdrop on this page so the feathered
     cream-gradient doesn't bleed onto the dark color blocks.
     :global wrapper is required because Astro scopes <style> by default
     and we need to touch the header rendered by Layout.astro. */
  :global(body:has(.pl-sup-block) .site-header) {
    -webkit-mask-image: none !important;
            mask-image: none !important;
  }
  :global(body:has(.pl-sup-block) .site-header::before) {
    background: var(--color-cream) !important;
  }

  /* Tablet+ collapse */
  @media (max-width: 900px) {
    .pl-sup-block { grid-template-columns: 1fr; }
    .pl-sup-block-art { min-height: 280px; padding: 2rem; }
    .pl-sup-block-body { padding: 3rem 2rem; max-width: none; }
    .pl-sup-block--reverse .pl-sup-block-art { order: 0; }
    .pl-sup-block--reverse .pl-sup-block-body { order: 1; margin-left: 0; }
    .pl-sup-pair-head { width: 32%; max-width: 200px; }
  }

  /* ============================================================
     Secondary door (reused from work-with-paula)
     ============================================================ */
  .pl-secondary-door {
