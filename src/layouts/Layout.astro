---
import '../styles/global.css';
import headerMark from '../assets/logos/HeaderMark.png';
import CloudsBG from '../components/CloudsBG.astro';

export interface Props {
  title: string;
  description?: string;
  /** When true, append "LMFT · CST · CSTS" next to the header logo (variant 5). */
  headerCredentials?: boolean;
}
const { title, description = "Paula Leech, LMFT, CST, CSTS — sex therapy, supervision, and courses.", headerCredentials = true } = Astro.props;

const nav = [
  { label: 'About',                 href: '/about' },
  { label: 'Work With Me',          href: '/work-with-paula' },
  { label: 'Supervision',           href: '/supervision' },
  { label: 'Courses & Trainings',   href: '/courses' },
  { label: 'Press',                 href: '/press' },
  { label: 'Contact & Scheduling',  href: '/contact' },
];
const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
// Force https for OG image URL — cloudflared tunnels and proxies hand us http internally
// but the page is served over https, and iMessage/social cards reject mixed-protocol URLs.
const ogOrigin = Astro.url.origin.replace(/^http:/, 'https:');
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <!-- Social / link previews (Open Graph + Twitter Card).
         Use Astro.url.origin so previews work on whatever host is serving the page
         (production, branch deploys, cloudflared tunnels) rather than hardcoding Astro.site. -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${ogOrigin}${BASE}/og/share-image.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={`${ogOrigin}${Astro.url.pathname}`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${ogOrigin}${BASE}/og/share-image.png`} />
    <link rel="icon" type="image/svg+xml" href={`${BASE}/favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT,WONK@0,9..144,300..900,0..100,0..1;1,9..144,300..900,0..100,0..1&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" />
    <title>{title}</title>
  </head>
  <body>
    <CloudsBG />
    <header class="site-header sticky top-0 z-30" style="overflow: visible;">
      <div class="mx-auto max-w-[1400px] px-12 lg:px-20 py-5 flex items-center justify-between gap-4" style="position: relative;">
        <a href={`${BASE}/`} class="flex items-center gap-3 shrink-0" aria-label="Paula Leech — Home" style="position: relative;">
          <img src={headerMark.src} alt="Paula Leech" style="height: 132px; width: auto; max-width: none; display: block; margin-top: -39px; margin-bottom: -45px; flex-shrink: 0;" />
          {headerCredentials && (
            <span class="pl-label hidden xl:inline" style="font-size: 0.7rem; line-height: 1.3; white-space: nowrap;">
              LMFT · CST · CSTS
            </span>
          )}
        </a>
        <nav class="hidden md:flex items-center gap-6 lg:gap-8">
          {nav.map(n => {
            const fullHref = `${BASE}${n.href}`;
            const hrefPath = n.href.split('#')[0];
            const curPath = (Astro.url.pathname || '/').replace(/\/$/, '');
            const navPath = `${BASE}${hrefPath}`.replace(/\/$/, '');
            // Active if current path equals the nav path, OR (for hash-anchor entries) starts with it.
            const isActive = hrefPath !== '/' && (curPath === navPath || curPath.startsWith(navPath + '/'));
            return (
              <a href={fullHref} class={`text-sm relative group whitespace-nowrap ${isActive ? 'is-active' : ''}`} aria-current={isActive ? 'page' : undefined} style="color: var(--color-ink);">
                <span class="transition-colors group-hover:text-[var(--color-plum)]" style={isActive ? 'color: var(--color-plum);' : undefined}>{n.label}</span>
                <span class={`absolute -bottom-1 left-0 h-px bg-[var(--color-plum)] transition-all duration-300 group-hover:w-full ${isActive ? 'w-full' : 'w-0'}`}></span>
              </a>
            );
          })}
        </nav>
        <div class="flex items-center gap-2 shrink-0">
          <button id="pl-mobile-nav-toggle" class="md:hidden pl-mobile-nav-btn" aria-label="Open menu" aria-expanded="false" aria-controls="pl-mobile-nav">
            <span></span><span></span><span></span>
          </button>
          <a href="tel:+16025706657" class="pl-pill" aria-label="Call Paula">Call</a>
          <a href="mailto:paula@paulaleech.com" class="pl-pill" style="background: var(--color-plum);">Email</a>
        </div>
      </div>
      <div id="pl-mobile-nav" class="pl-mobile-nav md:hidden" hidden>
        <nav class="flex flex-col px-12 py-2">
          {nav.map(n => (
            <a href={`${BASE}${n.href}`} class="block py-4 text-lg" style="color: var(--color-ink); border-bottom: 1px solid color-mix(in srgb, var(--color-ink) 12%, transparent);">{n.label}</a>
          ))}
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="mt-40 border-t" style="border-color: color-mix(in srgb, var(--color-ink) 15%, transparent);">
      <!-- Newsletter band (footer placement) -->
      <div class="mx-auto max-w-[1400px] px-12 lg:px-20 py-16 border-b" style="border-color: color-mix(in srgb, var(--color-ink) 15%, transparent);">
        <div class="pl-grid items-end">
          <div class="col-span-12 md:col-span-6">
            <p class="pl-label">The Newsletter</p>
            <h3 style="font-family: var(--font-display); font-style: italic; font-weight: 400; font-size: clamp(1.6rem, 2.6vw, 2.25rem); line-height: 1.1; margin-top: 0.5rem; letter-spacing: -0.015em;">
              Occasional letters.
            </h3>
          </div>
          <div class="col-span-12 md:col-span-6 mt-6 md:mt-0">
            <form data-newsletter="footer" class="flex flex-col sm:flex-row gap-3" onsubmit="event.preventDefault(); event.target.querySelector('[data-msg]').textContent = 'Thanks. Will let you know when this is wired up.';">
              <input
                type="email"
                required
                name="email"
                placeholder="you@example.com"
                aria-label="Email address"
                class="flex-1 px-4 py-3 rounded-full"
                style="background: transparent; border: 1px solid color-mix(in srgb, var(--color-ink) 30%, transparent); color: var(--color-ink); font-size: 1rem;"
              />
              <button type="submit" class="pl-pill" style="padding: 0.85rem 1.6rem;">Subscribe</button>
              <span data-msg class="text-sm self-center" style="color: var(--color-plum);"></span>
            </form>
            <p class="pl-label mt-3" style="font-size: 0.65rem; opacity: 0.7;">Backend pending — stub form for layout only.</p>
          </div>
        </div>
      </div>

      <div class="mx-auto max-w-[1400px] px-12 lg:px-20 py-20 pl-grid">
        <div class="col-span-12 md:col-span-4">
          <div style="font-family: var(--font-display); font-size: 2.25rem; line-height: 1;">paula leech</div>
          <p class="pl-label mt-3">lmft · cst · csts</p>
          <p class="mt-6 text-sm" style="color: var(--color-ink-soft); max-width: 28ch;">
            Sex therapy in Massachusetts, Oregon &amp; New York. Supervision worldwide. Courses online.
          </p>
        </div>
        <div class="col-span-6 md:col-span-3 mt-10 md:mt-0">
          <p class="pl-label mb-4">Contact</p>
          <a href="mailto:paula@paulaleech.com" class="block text-sm mt-2 hover:text-[var(--color-plum)] transition-colors">paula@paulaleech.com</a>
          <a href="tel:+16025706657" class="block text-sm mt-2 hover:text-[var(--color-plum)] transition-colors">(602) 570-6657</a>
          <a href="https://instagram.com/paulaleechtherapy" class="block text-sm mt-2 hover:text-[var(--color-plum)] transition-colors" target="_blank" rel="noopener">@paulaleechtherapy</a>
        </div>
        <div class="col-span-6 md:col-span-3 mt-10 md:mt-0">
          <p class="pl-label mb-4">Site</p>
          {nav.map(n => (
            <a href={`${BASE}${n.href}`} class="block text-sm mt-2 hover:text-[var(--color-plum)] transition-colors">{n.label}</a>
          ))}
        </div>
        <div class="col-span-12 md:col-span-2 mt-10 md:mt-0 text-right hidden md:block">
          <p class="pl-label">© 2026</p>
        </div>
      </div>
    </footer>

    <script is:inline src={`${BASE}/annotate.js`}></script>
    <script is:inline>
      document.documentElement.classList.add('js');
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting) { e.target.classList.add('is-in'); io.unobserve(e.target); }
        }
      }, { threshold: 0.12 });
      document.querySelectorAll('.pl-reveal').forEach(el => io.observe(el));

      // Mobile nav toggle
      (function () {
        const btn = document.getElementById('pl-mobile-nav-toggle');
        const panel = document.getElementById('pl-mobile-nav');
        if (!btn || !panel) return;
        const close = () => { panel.hidden = true; btn.setAttribute('aria-expanded', 'false'); btn.classList.remove('is-open'); document.body.style.overflow=''; };
        const open  = () => { panel.hidden = false; btn.setAttribute('aria-expanded', 'true');  btn.classList.add('is-open');    document.body.style.overflow='hidden'; };
        btn.addEventListener('click', () => panel.hidden ? open() : close());
        panel.querySelectorAll('a').forEach(a => a.addEventListener('click', close));
        document.addEventListener('keydown', e => { if (e.key === 'Escape') close(); });
        // Close if resized into desktop range
        window.matchMedia('(min-width: 768px)').addEventListener('change', e => { if (e.matches) close(); });
      })();

      // Fit heads vertically between header and the next section (e.g. #in-short).
      // Centers each .pl-fit-vertical wrapper in that gap; scales the inner img
      // down if it would overflow.
      (() => {
        const header = document.querySelector('header');
        const next   = document.getElementById('in-short');
        const heads  = Array.from(document.querySelectorAll('.pl-fit-vertical'));
        if (!header || !next || !heads.length) return;

        const SAFE = 40; // px padding inside the available zone

        // Cache each img's original inline width so we can restore it every fit()
        // (mid-scroll reloads can run fit before images load; clearing width and
        // not restoring leaves the image stuck at natural pixel dims).
        const originalWidths = new Map();
        for (const wrapper of heads) {
          const img = wrapper.querySelector('img');
          if (img) originalWidths.set(img, img.style.width || '');
        }

        function fit() {
          // Header is position: sticky — its bounding rect tracks viewport, not doc.
          // But it always sits at document Y = 0, so headerBottom is just its height.
          // For next (in-short), use getBoundingClientRect + scrollY for accurate doc Y.
          const headerH      = header.offsetHeight;
          const headerBottom = headerH;
          const nextTop      = next.getBoundingClientRect().top + window.scrollY;
          const available    = nextTop - headerBottom;
          const center       = headerBottom + available / 2;
          const maxH         = Math.max(120, available - SAFE * 2);

          for (const wrapper of heads) {
            const img = wrapper.querySelector('img');
            // Reset so we measure the natural responsive size cleanly
            img.style.maxHeight = '';
            img.style.width = originalWidths.get(img) || '';
            const naturalH = img.offsetHeight;
            let h = naturalH;
            if (naturalH > maxH) {
              // Need to scale down — cap height AND switch width to auto so aspect ratio survives
              img.style.maxHeight = maxH + 'px';
              img.style.width = 'auto';
              h = maxH;
            }
            const heroOffset = wrapper.offsetParent
              ? wrapper.offsetParent.getBoundingClientRect().top + window.scrollY
              : 0;
            wrapper.style.top = (center - h / 2 - heroOffset) + 'px';
          }
        }

        fit();
        window.addEventListener('resize', fit, { passive: true });
        // Re-run after fonts/images load (heights can shift)
        window.addEventListener('load', fit);
        // Re-fit when each head image loads (mid-scroll reload: image may not be
        // ready on first call, making offsetHeight tiny and the head collapse)
        for (const wrapper of heads) {
          const img = wrapper.querySelector('img');
          if (img && !img.complete) img.addEventListener('load', fit, { once: true });
        }
        // Re-fit when #in-short shifts (its position determines the available zone)
        if (window.ResizeObserver) {
          const ro = new ResizeObserver(() => fit());
          ro.observe(next);
          ro.observe(document.body);
        }
      })();
      // Each head has a target offset proportional to scroll position; current
      // chases target with a slow lerp so motion feels delayed but not springy.
      (() => {
        const els = Array.from(document.querySelectorAll('.pl-momentum'));
        if (!els.length) return;
        const state = els.map(el => ({
          el,
          scrollAmp: parseFloat(el.dataset.scroll || '0.15'),
          resizeAmp: parseFloat(el.dataset.resize || '0.3'),
          y: 0, x: 0,    // current (rendered) offset
          ty: 0, tx: 0,  // target offset
        }));
        const refScroll = window.scrollY;
        let refW = window.innerWidth;
        let refH = window.innerHeight;

        const MAX_OFFSET = 18;
        const LAG        = 0.10;  // 0..1, lower = lazier
        const EPS        = 0.04;

        function clamp(v) { return Math.max(-MAX_OFFSET, Math.min(MAX_OFFSET, v)); }

        // Target is a function of distance from initial position — no momentum, no drift
        function updateTargets() {
          const dy = window.scrollY - refScroll;
          const dw = window.innerWidth  - refW;
          const dh = window.innerHeight - refH;
          for (const s of state) {
            // Damp the target itself so it asymptotes — scrolling forever doesn't drift forever
            s.ty = clamp(dy * s.scrollAmp * 0.18) + clamp(dh * s.resizeAmp * 0.4);
            s.tx = clamp(dw * s.resizeAmp * 0.4);
          }
        }

        window.addEventListener('scroll', updateTargets, { passive: true });
        window.addEventListener('resize', updateTargets, { passive: true });

        function tick() {
          for (const s of state) {
            s.y += (s.ty - s.y) * LAG;
            s.x += (s.tx - s.x) * LAG;
            if (Math.abs(s.y - s.ty) < EPS && Math.abs(s.ty) < EPS) { s.y = 0; s.ty = 0; }
            if (Math.abs(s.x - s.tx) < EPS && Math.abs(s.tx) < EPS) { s.x = 0; s.tx = 0; }
            s.el.style.transform = (s.x === 0 && s.y === 0)
              ? ''
              : `translate3d(${s.x.toFixed(2)}px, ${s.y.toFixed(2)}px, 0)`;
          }
          requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
      })();
    </script>
  </body>
</html>
