---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
}
const { title, description = "Paula Leech, LMFT, CST, CSTS — sex therapy, supervision, and courses." } = Astro.props;

const nav = [
  { letter: 'A.', label: 'About',   href: '/about' },
  { letter: 'W.', label: 'Work',    href: '/work-with-paula' },
  { letter: 'C.', label: 'Courses', href: '/courses' },
  { letter: 'B.', label: 'Book',    href: '/book' },
];
const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${BASE}/favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT,WONK@0,9..144,300..900,0..100,0..1;1,9..144,300..900,0..100,0..1&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" />
    <title>{title}</title>
  </head>
  <body>
    <header class="sticky top-0 z-30 backdrop-blur" style="background: color-mix(in srgb, var(--color-cream) 88%, transparent);">
      <div class="mx-auto max-w-[1400px] px-6 lg:px-10 py-4 flex items-center justify-between">
        <a href={`${BASE}/`} class="flex items-baseline gap-2" aria-label="Paula Leech — Home">
          <span style="font-family: var(--font-display); font-size: 1.4rem; font-weight: 500; letter-spacing: -0.02em;">paula leech</span>
        </a>
        <nav class="hidden md:flex items-center gap-7">
          {nav.map(n => (
            <a href={`${BASE}${n.href}`} class="flex items-baseline gap-1.5 group">
              <span class="pl-label group-hover:text-[var(--color-plum)] transition-colors">{n.letter}</span>
              <span class="text-sm group-hover:text-[var(--color-plum)] transition-colors">{n.label}</span>
            </a>
          ))}
        </nav>
        <div class="flex items-center gap-3">
          <a href="tel:+15035551234" class="pl-pill" aria-label="Call Paula">
            <span>Call</span>
          </a>
          <a href="mailto:paula@paulaleech.com" class="pl-pill" style="background: var(--color-plum);">
            <span>Email</span>
          </a>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="mt-32 border-t" style="border-color: color-mix(in srgb, var(--color-ink) 15%, transparent);">
      <div class="mx-auto max-w-[1400px] px-6 lg:px-10 py-16 pl-grid">
        <div class="col-span-12 md:col-span-4">
          <div style="font-family: var(--font-display); font-size: 2rem; line-height: 1;">paula leech</div>
          <p class="pl-label mt-2">lmft · cst · csts</p>
          <p class="mt-6 text-sm" style="color: var(--color-ink-soft); max-width: 28ch;">
            Sex therapy in Massachusetts &amp; Oregon. Supervision worldwide. Courses online.
          </p>
        </div>
        <div class="col-span-6 md:col-span-3 mt-10 md:mt-0">
          <p class="pl-label mb-3">Contact</p>
          <a href="mailto:paula@paulaleech.com" class="block text-sm">paula@paulaleech.com</a>
          <a href="tel:+15035551234" class="block text-sm mt-1">(503) 555-1234</a>
          <a href="https://instagram.com/paulaleechtherapy" class="block text-sm mt-1" target="_blank" rel="noopener">@paulaleechtherapy</a>
        </div>
        <div class="col-span-6 md:col-span-3 mt-10 md:mt-0">
          <p class="pl-label mb-3">Site</p>
          {nav.map(n => (
            <a href={`${BASE}${n.href}`} class="block text-sm mt-1">{n.label}</a>
          ))}
          <a href={`${BASE}/contact`} class="block text-sm mt-1">Contact</a>
        </div>
        <div class="col-span-12 md:col-span-2 mt-10 md:mt-0 text-right hidden md:block">
          <p class="pl-label">© 2026</p>
        </div>
      </div>
    </footer>

    <script is:inline>
      document.documentElement.classList.add('js');
      // Reveal on scroll
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting) { e.target.classList.add('is-in'); io.unobserve(e.target); }
        }
      }, { threshold: 0.15 });
      document.querySelectorAll('.pl-reveal').forEach(el => io.observe(el));
    </script>
  </body>
</html>
