---
import '../styles/global.css';
import headerMark from '../assets/logos/HeaderMark.png';

export interface Props {
  title: string;
  description?: string;
  /** When true, append "LMFT · CST · CSTS" next to the header logo (variant 5). */
  headerCredentials?: boolean;
}
const { title, description = "Paula Leech, LMFT, CST, CSTS — sex therapy, supervision, and courses.", headerCredentials = false } = Astro.props;

const nav = [
  { label: 'About',         href: '/about' },
  { label: 'Work With Me',  href: '/work-with-paula' },
  { label: 'Courses',       href: '/courses' },
  { label: 'My Book',       href: '/book' },
  { label: 'Contact',       href: '/contact' },
];
const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${BASE}/favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT,WONK@0,9..144,300..900,0..100,0..1;1,9..144,300..900,0..100,0..1&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" />
    <title>{title}</title>
  </head>
  <body>
    <header class="sticky top-0 z-30 backdrop-blur" style="background: color-mix(in srgb, var(--color-cream) 88%, transparent); overflow: visible;">
      <div class="mx-auto max-w-[1400px] px-12 lg:px-20 py-5 flex items-center justify-between" style="position: relative;">
        <a href={`${BASE}/`} class="flex items-center gap-3" aria-label="Paula Leech — Home" style="position: relative;">
          <img src={headerMark.src} alt="Paula Leech" style="height: 120px; width: auto; display: block; margin-top: -40px; margin-bottom: -36px;" />
          {headerCredentials && (
            <span class="pl-label hidden sm:inline" style="font-size: 0.7rem; line-height: 1.3; white-space: nowrap;">
              LMFT · CST · CSTS
            </span>
          )}
        </a>
        <nav class="hidden md:flex items-center gap-8">
          {nav.map(n => (
            <a href={`${BASE}${n.href}`} class="text-sm relative group" style="color: var(--color-ink);">
              <span class="transition-colors group-hover:text-[var(--color-plum)]">{n.label}</span>
              <span class="absolute -bottom-1 left-0 w-0 h-px bg-[var(--color-plum)] transition-all duration-300 group-hover:w-full"></span>
            </a>
          ))}
        </nav>
        <div class="flex items-center gap-2">
          <a href="tel:+150****1234" class="pl-pill" aria-label="Call Paula">Call</a>
          <a href="mailto:paula@paulaleech.com" class="pl-pill" style="background: var(--color-plum);">Email</a>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="mt-40 border-t" style="border-color: color-mix(in srgb, var(--color-ink) 15%, transparent);">
      <div class="mx-auto max-w-[1400px] px-12 lg:px-20 py-20 pl-grid">
        <div class="col-span-12 md:col-span-4">
          <div style="font-family: var(--font-display); font-size: 2.25rem; line-height: 1;">paula leech</div>
          <p class="pl-label mt-3">lmft · cst · csts</p>
          <p class="mt-6 text-sm" style="color: var(--color-ink-soft); max-width: 28ch;">
            Sex therapy in Massachusetts &amp; Oregon. Supervision worldwide. Courses online.
          </p>
        </div>
        <div class="col-span-6 md:col-span-3 mt-10 md:mt-0">
          <p class="pl-label mb-4">Contact</p>
          <a href="mailto:paula@paulaleech.com" class="block text-sm mt-2 hover:text-[var(--color-plum)] transition-colors">paula@paulaleech.com</a>
          <a href="tel:+150****1234" class="block text-sm mt-2 hover:text-[var(--color-plum)] transition-colors">(503) 555-1234</a>
          <a href="https://instagram.com/paulaleechtherapy" class="block text-sm mt-2 hover:text-[var(--color-plum)] transition-colors" target="_blank" rel="noopener">@paulaleechtherapy</a>
        </div>
        <div class="col-span-6 md:col-span-3 mt-10 md:mt-0">
          <p class="pl-label mb-4">Site</p>
          {nav.map(n => (
            <a href={`${BASE}${n.href}`} class="block text-sm mt-2 hover:text-[var(--color-plum)] transition-colors">{n.label}</a>
          ))}
        </div>
        <div class="col-span-12 md:col-span-2 mt-10 md:mt-0 text-right hidden md:block">
          <p class="pl-label">© 2026</p>
        </div>
      </div>
    </footer>

    <script is:inline src={`${BASE}/annotate.js`}></script>
    <script is:inline>
      document.documentElement.classList.add('js');
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting) { e.target.classList.add('is-in'); io.unobserve(e.target); }
        }
      }, { threshold: 0.12 });
      document.querySelectorAll('.pl-reveal').forEach(el => io.observe(el));

      // Subtle push + small overshoot: scroll/resize nudges each head; it eases
      // back past zero a touch, then settles. When motion settles, transform
      // clears and the CSS ambient float on the inner img takes over.
      (() => {
        const els = Array.from(document.querySelectorAll('.pl-momentum'));
        if (!els.length) return;
        const state = els.map(el => ({
          el,
          scrollAmp: parseFloat(el.dataset.scroll || '0.15'),
          resizeAmp: parseFloat(el.dataset.resize || '0.3'),
          // physics state
          y: 0, x: 0,    // current position
          vy: 0, vx: 0,  // current velocity
        }));
        let lastScroll = window.scrollY;
        let lastW = window.innerWidth;
        let lastH = window.innerHeight;

        const MAX_OFFSET = 22;      // px cap on impulse
        const SPRING     = 0.09;    // stiffer = quicker stop, no springy feel
        const DAMPING    = 0.72;    // heavy damping — kills oscillation
        const EPS        = 0.04;

        function clamp(v) { return Math.max(-MAX_OFFSET, Math.min(MAX_OFFSET, v)); }

        window.addEventListener('scroll', () => {
          const y = window.scrollY;
          const dy = y - lastScroll;
          lastScroll = y;
          // Inject as a velocity impulse so motion reads as momentum
          for (const s of state) s.vy = clamp(s.vy + dy * s.scrollAmp * 0.55);
        }, { passive: true });

        window.addEventListener('resize', () => {
          const w = window.innerWidth, h = window.innerHeight;
          const dw = w - lastW, dh = h - lastH;
          lastW = w; lastH = h;
          for (const s of state) {
            s.vx = clamp(s.vx + dw * s.resizeAmp * 0.5);
            s.vy = clamp(s.vy + dh * s.resizeAmp * 0.5);
          }
        }, { passive: true });

        function tick() {
          for (const s of state) {
            // spring toward 0
            s.vy += -s.y * SPRING;
            s.vx += -s.x * SPRING;
            s.vy *= DAMPING;
            s.vx *= DAMPING;
            s.y  += s.vy;
            s.x  += s.vx;
            // Clean zero when truly settled
            if (Math.abs(s.y) < EPS && Math.abs(s.vy) < EPS) { s.y = 0; s.vy = 0; }
            if (Math.abs(s.x) < EPS && Math.abs(s.vx) < EPS) { s.x = 0; s.vx = 0; }
            s.el.style.transform = (s.x === 0 && s.y === 0)
              ? ''
              : `translate3d(${s.x.toFixed(2)}px, ${s.y.toFixed(2)}px, 0)`;
          }
          requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
      })();
    </script>
  </body>
</html>
